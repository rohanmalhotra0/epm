      "Scenario",
      "Entity"
    ],
    "has_source": true,
    "purpose": "Incremental Rollup \u2014 aggregates the current slice for the chosen scenario/entity.",
    "source": "FIX(&CurrYr, {Scenario}, \"Working\", {Entity})\n  AGG(\"Account\", \"Entity\");\nENDFIX\n",
