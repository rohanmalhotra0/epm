<?xml version = '1.0' encoding = 'UTF-8'?>
<ImportFormats>
   <ImportGroupsLcmVO/>
   <ImportGroupsAdapterVO/>
   <ImportGroupsFileLcmVO>
      <ImportGroupsFileLcmVORow>
         <Impgroupkey>PCF_DATA_DAILY</Impgroupkey>
         <Impgroupdesc null="true"/>
         <SourceSystemName>Data Source</SourceSystemName>
         <Impgroupfiletype>DELIMITED</Impgroupfiletype>
         <Impgroupdelimiter>,</Impgroupdelimiter>
         <Impdrillrequestmethod null="true"/>
         <Impdrillurl null="true"/>
         <EpmSourceSystemName>PCF Data Staging Area - DAILY</EpmSourceSystemName>
         <Impodiscenario>DATASOURCE</Impodiscenario>
         <TargetApplicationName>MCW_PCF</TargetApplicationName>
         <ApplicationName>MCW_PCF-OEP_DCSH</ApplicationName>
         <ImportItemDetailsForFileLcmVO>
            <ImportItemDetailsForFileLcmVORow>
               <Impfldfieldname>ACCOUNT</Impfldfieldname>
               <Impfldfixedtext null="true"/>
               <Impfldsourcecolname>Source</Impfldsourcecolname>
               <Impfldstartpos>1</Impfldstartpos>
               <Impfldlength>1</Impfldlength>
               <Impfldtargetexp>copysource()</Impfldtargetexp>
            </ImportItemDetailsForFileLcmVORow>
            <ImportItemDetailsForFileLcmVORow>
               <Impfldfieldname>AMOUNT</Impfldfieldname>
               <Impfldfixedtext>NZP</Impfldfixedtext>
               <Impfldsourcecolname>Measure</Impfldsourcecolname>
               <Impfldstartpos>1</Impfldstartpos>
               <Impfldlength>1</Impfldlength>
               <Impfldtargetexp null="true"/>
            </ImportItemDetailsForFileLcmVORow>
            <ImportItemDetailsForFileLcmVORow>
               <Impfldfieldname>ENTITY</Impfldfieldname>
               <Impfldfixedtext null="true"/>
               <Impfldsourcecolname>Legal Entity</Impfldsourcecolname>
               <Impfldstartpos>1</Impfldstartpos>
               <Impfldlength>1</Impfldlength>
               <Impfldtargetexp>prefix("LE_")</Impfldtargetexp>
            </ImportItemDetailsForFileLcmVORow>
            <ImportItemDetailsForFileLcmVORow>
               <Impfldfieldname>UD1</Impfldfieldname>
               <Impfldfixedtext>constant("No Input")</Impfldfixedtext>
               <Impfldstartpos>1</Impfldstartpos>
               <Impfldlength>1</Impfldlength>
               <Impfldtargetexp>constant("OEP_Working")</Impfldtargetexp>
            </ImportItemDetailsForFileLcmVORow>
            <ImportItemDetailsForFileLcmVORow>
               <Impfldfieldname>UD10</Impfldfieldname>
               <Impfldfixedtext null="true"/>
               <Impfldsourcecolname>Year</Impfldsourcecolname>
               <Impfldstartpos>1</Impfldstartpos>
               <Impfldlength>1</Impfldlength>
               <Impfldtargetexp>copysource()</Impfldtargetexp>
            </ImportItemDetailsForFileLcmVORow>
            <ImportItemDetailsForFileLcmVORow>
               <Impfldfieldname>UD2</Impfldfieldname>
               <Impfldfixedtext null="true"/>
               <Impfldsourcecolname>Forecast Method</Impfldsourcecolname>
               <Impfldstartpos>1</Impfldstartpos>
               <Impfldlength>1</Impfldlength>
               <Impfldtargetexp>condition=if (UD2 == "FORECAST_METHOD_SMART_DRIVER") return "OCF_Smart Drivers" 
else if (UD2 == "FORECAST_METHOD_PREDICTION") return "OCF_Short Term Machine Learning Prediction" </Impfldtargetexp>
            </ImportItemDetailsForFileLcmVORow>
            <ImportItemDetailsForFileLcmVORow>
               <Impfldfieldname>UD3</Impfldfieldname>
               <Impfldfixedtext null="true"/>
               <Impfldsourcecolname>Bank Account</Impfldsourcecolname>
               <Impfldstartpos>1</Impfldstartpos>
               <Impfldlength>1</Impfldlength>
               <Impfldtargetexp>condition=if (UD3== "NO_VALUE") return "OEP_Any Bank" 
else return "BA_" + UD3</Impfldtargetexp>
            </ImportItemDetailsForFileLcmVORow>
            <ImportItemDetailsForFileLcmVORow>
               <Impfldfieldname>UD4</Impfldfieldname>
               <Impfldfixedtext null="true"/>
               <Impfldsourcecolname>Party</Impfldsourcecolname>
               <Impfldstartpos>1</Impfldstartpos>
               <Impfldlength>1</Impfldlength>
               <Impfldtargetexp>condition=if (UD4 == "PARTY_NO_VALUE") return "OEP_Any Party" 
else return UD4</Impfldtargetexp>
            </ImportItemDetailsForFileLcmVORow>
            <ImportItemDetailsForFileLcmVORow>
               <Impfldfieldname>UD5</Impfldfieldname>
               <Impfldfixedtext null="true"/>
               <Impfldsourcecolname>Business Unit</Impfldsourcecolname>
               <Impfldstartpos>1</Impfldstartpos>
               <Impfldlength>1</Impfldlength>
               <Impfldtargetexp>condition=if (UD5== "NO_VALUE") return "OEP_Any Business Unit" 
else return "BU_" + UD5</Impfldtargetexp>
            </ImportItemDetailsForFileLcmVORow>
            <ImportItemDetailsForFileLcmVORow>
               <Impfldfieldname>UD6</Impfldfieldname>
               <Impfldfixedtext null="true"/>
               <Impfldsourcecolname>Source Detail</Impfldsourcecolname>
               <Impfldstartpos>1</Impfldstartpos>
               <Impfldlength>1</Impfldlength>
               <Impfldtargetexp>constant("OEP_Any Category")</Impfldtargetexp>
            </ImportItemDetailsForFileLcmVORow>
            <ImportItemDetailsForFileLcmVORow>
               <Impfldfieldname>UD7</Impfldfieldname>
               <Impfldfixedtext null="true"/>
               <Impfldsourcecolname>Currency</Impfldsourcecolname>
               <Impfldstartpos>1</Impfldstartpos>
               <Impfldlength>1</Impfldlength>
               <Impfldtargetexp>copysource()</Impfldtargetexp>
            </ImportItemDetailsForFileLcmVORow>
            <ImportItemDetailsForFileLcmVORow>
               <Impfldfieldname>UD8</Impfldfieldname>
               <Impfldfixedtext null="true"/>
               <Impfldsourcecolname>Day</Impfldsourcecolname>
               <Impfldstartpos>1</Impfldstartpos>
               <Impfldlength>1</Impfldlength>
               <Impfldtargetexp>copysource()</Impfldtargetexp>
            </ImportItemDetailsForFileLcmVORow>
            <ImportItemDetailsForFileLcmVORow>
               <Impfldfieldname>UD9</Impfldfieldname>
               <Impfldfixedtext null="true"/>
               <Impfldsourcecolname>Scenario</Impfldsourcecolname>
               <Impfldstartpos>1</Impfldstartpos>
               <Impfldlength>1</Impfldlength>
               <Impfldtargetexp>condition=if (UD9 == "Actual" or UD9 == "Actual_CurrMonth") return "OEP_Actual" 
else if (UD9 == "Forecast_CurrMonth" or UD9 == "Forecast") return "OEP_Forecast" 
</Impfldtargetexp>
            </ImportItemDetailsForFileLcmVORow>
         </ImportItemDetailsForFileLcmVO>
      </ImportGroupsFileLcmVORow>
   </ImportGroupsFileLcmVO>
</ImportFormats>