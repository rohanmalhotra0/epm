<?xml version = '1.0' encoding = 'UTF-8'?>
<HBRRepo><variables><variable name="OCF_Currency" type="member" usage="const" id="2" product="Planning"><property name="application">MCW_PCF</property><property name="dimensionInputMode">type</property><property name="dimensionType">Currency</property><property name="prompt_text">LABEL_OCF_CASH_FORECST_PRMPT_CURR</property><property name="scope">ruleset</property><property name="seeded">true</property><value/></variable><variable name="OCF_Entity" type="member" usage="const" id="1" product="Planning"><property name="application">MCW_PCF</property><property name="dimensionInputMode">type</property><property name="dimensionType">Entity</property><property name="prompt_text">LABEL_OCF_CASH_FORECST_PRMPT_ENTITY</property><property name="scope">ruleset</property><property name="seeded">true</property><value/></variable></variables><rulesets/><rules><rule id="1" name="OCF_Periodic Adjustments For Fixed Assets" product="Planning"><property name="application">MCW_PCF</property><property name="plantype">OEP_PCSH</property><property name="seeded">true</property><variable_references><variable_reference name="OCF_Entity" id="1"><property name="application">MCW_PCF</property><property name="hidden">true</property><property name="rule_name">OCF_Periodic Adjustments For Fixed Assets</property><property name="seq">1</property><property name="type">3</property><property name="useAsOverrideValue">false</property><property name="validation_value">"OEP_No Entity"</property></variable_reference><variable_reference name="OCF_Currency" id="2"><property name="application">MCW_PCF</property><property name="hidden">true</property><property name="rule_name">OCF_Periodic Adjustments For Fixed Assets</property><property name="seq">2</property><property name="type">3</property><property name="useAsOverrideValue">false</property><property name="validation_value">"No Currency"</property></variable_reference></variable_references><script type="groovy">					/*RTPS: {OCF_Entity},{OCF_Currency} */  
					/*
					 *	Purpose: This rule is used to perform adjustments in Cash from Financial Activities form.
					 *		1. For each modified cell in the form, creates grid to pull the before value of the cell
					 *		2. The difference amount will be stored in the adjustment member.
					 *		3. Adjustment amount +orginial amount will be shown as the total forecast amount in the form.
					 *		4. Adjustment is stored in Any member of each dimension so that rolls up correctly across the dimensions.					
					*/
					StringBuilder cscript = new StringBuilder(); 
					def calcString;
					String flexDim1Name = "flexDimension1";
					String flexDim2Name = "flexDimension2";
					String flexDim3Name = "flexDimension3";
					String partyDimName="Party";
					String buDimName="Business Unit";
					String prjDimName="Category"
					String cashElementDimName = "Forecast Method";
					String bankDimName="Bank";
					String noBankMember="OEP_Any "+ bankDimName; 
					String entityDimName = "Entity";					
					List&lt;String> noFixMembers=[];
					String noFixMembersStr;
					String entityMember = rtps.OCF_Entity.member.name; 
					String currencyMember =rtps.OCF_Currency.member.name;
					Application application = operation.application;
					Cube cashFlowCube = application.getCube("OEP_PCSH");
					List&lt;String> fixedAssetsLineItems=application.getDimension("Line Item",cashFlowCube).getEvaluatedMembers('ILvl0Descendants("OCF_Cash Outflows for Fixed Assets")',cashFlowCube).collect{it.toString()};
					noFixMembers.add('"'+currencyMember+'"');
					if(application.hasDimension(flexDim1Name, cashFlowCube)) 
					{
					  noFixMembers.add('"No '+ flexDim1Name +'"');  
					}
					if(operation.application.hasDimension(flexDim2Name, cashFlowCube))
					{
					  noFixMembers.add('"No '+ flexDim2Name +'"') ;  
					}
					if(operation.application.hasDimension(flexDim3Name, cashFlowCube))
					{
					  noFixMembers.add('"No '+ flexDim3Name +'"'); 
					}
					if(operation.application.hasDimension(partyDimName, cashFlowCube))
					{
					  noFixMembers.add('"OEP_Any '+ partyDimName +'"'); 
					}
					if(operation.application.hasDimension(buDimName, cashFlowCube))
					{
					  noFixMembers.add('"OEP_Any '+ buDimName +'"'); 
					}
					if(operation.application.hasDimension(prjDimName, cashFlowCube))
					{
					  noFixMembers.add('"OEP_Any '+ prjDimName +'"'); 
					}
					if(operation.application.hasDimension(bankDimName, cashFlowCube))
					{
					  noFixMembers.add('"OEP_Any '+ bankDimName +'"'); 
					}
					noFixMembersStr=noFixMembers.join(",");
					def assumptionGridDefBuilderPovDims = ["Scenario",  bankDimName]
					def assumptionGridDefBuilderPovSelection = [ ["OEP_Forecast"], [noBankMember] ]
					def addPovSelectionForAssumptionGrid = { String dimName -> 
						  if(application.hasDimension(dimName, cashFlowCube)) {
							assumptionGridDefBuilderPovDims.add(dimName)
							assumptionGridDefBuilderPovSelection &lt;&lt; ["Total $dimName".toString()]
						  }
						}   
						addPovSelectionForAssumptionGrid.call(flexDim1Name)
						addPovSelectionForAssumptionGrid.call(flexDim2Name)
						addPovSelectionForAssumptionGrid.call(flexDim3Name)
						def addPovSelectionForAssumptionGridwithPrefix = { String dimName -> 
						if(application.hasDimension(dimName, cashFlowCube)) {
							assumptionGridDefBuilderPovDims.add(dimName)
							assumptionGridDefBuilderPovSelection &lt;&lt; ["OEP_Total $dimName".toString()]
						  }
						}     	
						addPovSelectionForAssumptionGridwithPrefix.call(partyDimName)
						addPovSelectionForAssumptionGridwithPrefix.call(buDimName)
						addPovSelectionForAssumptionGridwithPrefix.call(prjDimName)
						  if(operation.application.getCurrencyMode().equals(CurrencyMode.SIMPLIFIED_MULTI_CURRENCY))
						  {
							assumptionGridDefBuilderPovDims.add("Currency")
							assumptionGridDefBuilderPovSelection &lt;&lt; [currencyMember]
						  }
						  assumptionGridDefBuilderPovDims.add(entityDimName)
						  assumptionGridDefBuilderPovSelection.add([entityMember])
						  operation.grid.dataCellIterator({DataCell cell -> cell.edited}).each { it ->
					  String versionMemberName=it.getVersionName();
					  String yearMemberName=it.getYearName();
					  String lineItemMemberName=it.getAccountName();
					  String periodMemberName=it.getPeriodName();
					  List&lt;String> arrGridMbrs = new ArrayList&lt;String>();		
					  arrGridMbrs=it.getMemberNames()
					  Double  amtBeforeAdjustment
					  Double  amtAfterAdjustment =it.getData()
					  if (fixedAssetsLineItems.contains(lineItemMemberName)	)  
					  {
						  assumptionGridDefBuilderPovDims.add("Period");  
						  assumptionGridDefBuilderPovSelection.add([periodMemberName]);
						  assumptionGridDefBuilderPovDims.add("Version");  
						  assumptionGridDefBuilderPovSelection.add([versionMemberName]); 
						  assumptionGridDefBuilderPovDims.add("Years");  
						  assumptionGridDefBuilderPovSelection.add([yearMemberName]); 
						  DataGridDefinitionBuilder assumptionRevenueGridDefBuilder = cashFlowCube.dataGridDefinitionBuilder();
						  assumptionRevenueGridDefBuilder.addPov(assumptionGridDefBuilderPovDims, assumptionGridDefBuilderPovSelection);
						  assumptionGridDefBuilderPovDims.remove("Period"); 
						  assumptionGridDefBuilderPovSelection.remove([periodMemberName]);
						  assumptionGridDefBuilderPovDims.remove("Version");  
						  assumptionGridDefBuilderPovSelection.remove([versionMemberName]);
						  assumptionGridDefBuilderPovDims.remove("Years") ;
						  assumptionGridDefBuilderPovSelection.remove([yearMemberName]);
						  assumptionRevenueGridDefBuilder.addColumn(['Forecast Method'], [ ['"OCF_Forecasted"'] ]);
						  assumptionRevenueGridDefBuilder.addRow(['Line Item'], [ [lineItemMemberName] ]);
						 cashFlowCube.loadGrid(assumptionRevenueGridDefBuilder.build(), false).withCloseable {itCalc ->
						   itCalc.dataCellIterator.each { it2->
								 amtBeforeAdjustment=it2.getData()      
								}
						   }
						   Double adjustmentAmount=amtAfterAdjustment-amtBeforeAdjustment;
						  
							 calcString ="""
											FIX("$entityMember",$noFixMembersStr,"$versionMemberName","$yearMemberName","$lineItemMemberName","$periodMemberName")
												"OCF_Adjustments"=$adjustmentAmount;
											ENDFIX;
											
											"""          
						cscript.append(calcString);
						}
					}					
					return cscript;  						
			</script></rule></rules><components/><deployobjects><deployobject product="2" application="mcw_pcf" plantype="oep_pcsh" obj_id="1" obj_type="1" name="OCF_PERIODIC ADJUSTMENTS FOR FIXED ASSETS"/></deployobjects></HBRRepo>