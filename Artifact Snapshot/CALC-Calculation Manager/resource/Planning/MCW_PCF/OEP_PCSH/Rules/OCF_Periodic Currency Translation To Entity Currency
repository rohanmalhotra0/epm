		/***
		* This script reads currency dimension and generate the rates multiplier script.
	   
	   ***/
	   String getRatesMultiplerScript(List&lt;String> lstInputCurrencies,String ReportingCurrency,String noFixMemberJoin,String ratesType)	   
	   {			
			String defaultCurrency = operation.application.getDefaultCurrency().getName()
			String inputOfReportingCurrency = ReportingCurrency.split('_')[0];		
			String finalString ="";
			if (inputOfReportingCurrency  == defaultCurrency)
			{
				lstInputCurrencies.each { it ->
						String currencyValue= it.toString()
							if (defaultCurrency!=currencyValue)
							{
							finalString= finalString +  """("$currencyValue" * ("$ratesType"->$noFixMemberJoin->"$currencyValue"))+""";											
							}				 				
						}
			}
			else
			{
				lstInputCurrencies.each { it ->
				String currencyValue= it.toString()
					if (defaultCurrency!=currencyValue)
					{
						if (inputOfReportingCurrency == currencyValue) 
						 {
							finalString= finalString +  """("$defaultCurrency" * (1/"$ratesType"->$noFixMemberJoin->"$inputOfReportingCurrency"))+""";
						 }
						 else
						 {
							finalString= finalString +  """("$currencyValue" * ("$ratesType"->$noFixMemberJoin->"$currencyValue"/"$ratesType"->$noFixMemberJoin->"$inputOfReportingCurrency"))+""";
						 }
					}			 
				
				}
			}
			finalString=finalString+"$inputOfReportingCurrency";			
			return finalString;			
	   }
	  /***
	   * Currency Core logic script
	  ***/
	  String getCoreCurrencyTranslationScript(String lineItemDimName,String ReportingCurrency, String noFixMembersJoinStr ,List&lt;String> lstInputCurrencies)
			{
				String fxRatesEndingScript= getRatesMultiplerScript(lstInputCurrencies,ReportingCurrency,noFixMembersJoinStr,"FX Rates - Ending");
				String fxRatesAverageScript= getRatesMultiplerScript(lstInputCurrencies,ReportingCurrency,noFixMembersJoinStr,"FX Rates - Average");
				String fxRatesSumScript = lstInputCurrencies.join('"+"')
			
				String finalString ="""
												"$ReportingCurrency"(
														@CALCMODE(BOTTOMUP);
														@CALCMODE(BLOCK);
															if(@isUDA("$lineItemDimName", "Ending") and @isUDA("$lineItemDimName","Hsp_Currency"))
																	 "$ReportingCurrency"=$fxRatesEndingScript;
															elseif(@isUDA("$lineItemDimName", "Average") and @isUDA("$lineItemDimName","Hsp_Currency"))
																	 "$ReportingCurrency"=$fxRatesAverageScript;
															elseif(@isUDA("$lineItemDimName", "Saved Assumption") and @isUDA("$lineItemDimName","Hsp_Non-Currency"))
																	 "$ReportingCurrency"="$fxRatesSumScript";
															endif;);
									"""
			
				return finalString;
			}
	   
