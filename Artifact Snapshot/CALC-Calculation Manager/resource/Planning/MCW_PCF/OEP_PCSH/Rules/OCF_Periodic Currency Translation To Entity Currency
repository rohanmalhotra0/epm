	String generateCurrencyConverionCalcScriptForIntegration(Cube cashFlowCube,List&lt;String> scenarioMembers,String versionMember, List&lt;String> entityMembers ,String fixParallelDim)
	{
		StringBuilder cscript = new StringBuilder(); 
				boolean chkValidEntityList= false;
				boolean chkEntityIsFixParallel= false;				
				def calcString;
				String coreCurrencyScript ,entityValue,entityMember;
				boolean chkActual =false;
				List&lt;String> scenarioMemberList;
				String scenarioMemberListStr;
				String flexDim1Name = "flexDimension1";
				String flexDim2Name = "flexDimension2";
				String flexDim3Name = "flexDimension3";
				String currencyDimName="Currency";
				String partyDimName="Party";
				String bankDimName="Bank";
				String buDimName="Business Unit";
				String prjDimName="Category"
				String forecastMethodDimName = "Forecast Method";
				String yearDimName="Years"				
				String entityDimName = "Entity";
				String lineItemDimName = "Line Item";								
				List&lt;String> noFixMembers=[];
				List&lt;String> fixMembers=[];	
				List&lt;String> lstEntities = new ArrayList&lt;String>();	
				def isWeeklyEnabled = "Monthly" == "Weekly"
				def isMonthlyEnabled = "Monthly" == "Monthly"								
				String periodRollup;
				if (cashFlowCube.getEssbaseName() == "OEP_DCSH") 
				{
						periodRollup= "OEP_Daily YearTotal";
				}
				else
				{
					if (isMonthlyEnabled) periodRollup="YearTotal"	;
					if (isWeeklyEnabled)  periodRollup="OEP_Weekly YearTotal";
				}
				List&lt;String> lstPeriods=operation.application.getDimension("Period",cashFlowCube).getEvaluatedMembers('ILvl0Descendants("'+periodRollup+'")',cashFlowCube).collect{it.toString()};
				String startPeriod=lstPeriods.first();	
				String endPeriod=lstPeriods.last();								
				if (fixParallelDim==entityDimName) chkEntityIsFixParallel=true;				
				noFixMembers.add('"No '+ entityDimName +'"');
				if ( entityMembers.size() == 1 )			
				{	
					entityMember= entityMembers.join(",");					
					lstEntities=operation.application.getDimension(entityDimName,cashFlowCube).getEvaluatedMembers('ILvl0Descendants("'+entityMember+'")',cashFlowCube).collect{it.toString()};
					entityValue='@Relative("'+entityMember+'",0)';					
				}
				else
				{
					
					lstEntities=entityMembers;
					entityValue='"'+entityMembers.join('","')+'"'	;
					/*fixMembers.add('@LEVMBRS("'+lineItemDimName+'",0),@LEVMBRS("Period",0)');	*/
				}
					
				populateFixandNoFixMembers(cashFlowCube,forecastMethodDimName,fixMembers,noFixMembers)
				populateFixandNoFixMembers(cashFlowCube,bankDimName,fixMembers,noFixMembers)								
				populateFixandNoFixMembers(cashFlowCube,flexDim1Name,fixMembers,noFixMembers)
				populateFixandNoFixMembers(cashFlowCube,flexDim2Name,fixMembers,noFixMembers)
				populateFixandNoFixMembers(cashFlowCube,flexDim3Name,fixMembers,noFixMembers)
				populateFixandNoFixMembers(cashFlowCube,partyDimName,fixMembers,noFixMembers)
				populateFixandNoFixMembers(cashFlowCube,buDimName,fixMembers,noFixMembers)				
				if(operation.application.hasDimension(prjDimName, cashFlowCube))  noFixMembers.add('"No '+ prjDimName +'"');							
				String noFixMembersJoinStr=noFixMembers.join("->");							
				String fixMembersJoinStr=fixMembers.join(",");								
				List&lt;String> lstInputCurrencies=operation.application.getDimension("Currency",cashFlowCube).getEvaluatedMembers('ILvl0Descendants("Input Currencies")',cashFlowCube).collect{it.toString()};
				List&lt;String> lstReportingCurrencies=operation.application.getDimension("Currency",cashFlowCube).getEvaluatedMembers('ILvl0Descendants("Reporting Currencies")',cashFlowCube).collect{it.toString()};
				calcString="""
										SET UPDATECALC OFF;
										SET AGGMISSG ON;
										FIX($fixMembersJoinStr)
											FIX(@LEVMBRS("$prjDimName",0))
							"""	
				cscript.append(calcString) ;
				
				lstReportingCurrencies.each { it ->
					String ReportingCurrency= it.toString()
					String udaValueFromCurrency =ReportingCurrency.split('_')[0];					
					List&lt;String> entityList = operation.application.getDimension(entityDimName,cashFlowCube).getMembersWithUda(udaValueFromCurrency,false,cashFlowCube).collect{it.toString()};
					List&lt;String> uniqueEntityList=getUniqueList( lstEntities,entityList)
					String entityListStr=uniqueEntityList.join('","')	
					if( uniqueEntityList.size()>0)
					{
						chkValidEntityList=true;
							if (chkEntityIsFixParallel == true)
							{
								calcString="""																					
											FIXPARALLEL (4,	"$entityListStr")
										"""	
							}
							else
							{
							 calcString="""										
											FIX("$entityListStr")	
										"""	
							}			
							cscript.append(calcString) 
							coreCurrencyScript = getCoreCurrencyTranslationScript(lineItemDimName,ReportingCurrency,noFixMembersJoinStr,lstInputCurrencies)									
							if (checkForActual(scenarioMembers))
							{
								chkActual= true;								
									calcString="""										
													FIX("OEP_Actual","$versionMember")
														  FIX(&amp;OEP_PriorYr)	
															 FIX(@LEVMBRS("$lineItemDimName",0),@LEVMBRS("Period",0))
																$coreCurrencyScript
															 ENDFIX;
															 FIX("$ReportingCurrency",$startPeriod:$endPeriod)
																 "OCF_Opening Balance" (
																	@CALCMODE(BottomUp);
																	IF ( NOT @ISMBR("$startPeriod"))																											
																		"OCF_Opening Balance"= @PRIOR("OCF_Opening Balance")+( @PRIOR("OCF_Operating Cash Inflow")+ @PRIOR("OCF_Financing Cash Inflows")+@PRIOR("OCF_Investing Cash Inflows"))-( @PRIOR("OCF_Operating Cash Outflow")+ @PRIOR("OCF_Financing Cash Outflows")+ @PRIOR("OCF_Investing Cash Outflows")+@PRIOR("OCF_Cash Outflows for Fixed Assets"));
																	ENDIF;	
																	);
															 ENDFIX	
														  ENDFIX;	
														FIX(&amp;OEP_CurrYr)	
															 FIX(@LEVMBRS("$lineItemDimName",0),@LEVMBRS("Period",0))
																$coreCurrencyScript
															 ENDFIX;
															FIX("$ReportingCurrency",$startPeriod:&amp;OEP_ActPeriod)
															 "OCF_Opening Balance" (
																@CALCMODE(BottomUp);
																IF ( @ISMBR("$startPeriod"))									
																	"OCF_Opening Balance"= "OCF_Opening Balance"->&amp;OEP_PriorYr->"$endPeriod"+( "OCF_Operating Cash Inflow"->&amp;OEP_PriorYr->"$endPeriod"+ "OCF_Financing Cash Inflows"->&amp;OEP_PriorYr->"$endPeriod"+"OCF_Investing Cash Inflows"->&amp;OEP_PriorYr->"$endPeriod")-( "OCF_Operating Cash Outflow"->&amp;OEP_PriorYr->"$endPeriod"+ "OCF_Financing Cash Outflows"->&amp;OEP_PriorYr->"$endPeriod"+ "OCF_Investing Cash Outflows"->&amp;OEP_PriorYr->"$endPeriod" + "OCF_Cash Outflows for Fixed Assets"->&amp;OEP_PriorYr->"$endPeriod");
																ElSE
																	"OCF_Opening Balance"= @PRIOR("OCF_Opening Balance")+( @PRIOR("OCF_Operating Cash Inflow")+ @PRIOR("OCF_Financing Cash Inflows")+@PRIOR("OCF_Investing Cash Inflows"))-( @PRIOR("OCF_Operating Cash Outflow")+ @PRIOR("OCF_Financing Cash Outflows")+ @PRIOR("OCF_Investing Cash Outflows")+@PRIOR("OCF_Cash Outflows for Fixed Assets"));
																ENDIF;	
																);
															ENDFIX;	
														ENDFIX 
													ENDFIX;
											"""
								
								 cscript.append(calcString)
							}																						
							scenarioMemberList=(chkActual)? removeActualFromScenarios(scenarioMembers):scenarioMembers;								
							if (scenarioMemberList.size()>0)
							{
								scenarioMemberListStr= scenarioMemberList.join('","');
								
								calcString="""		
												FIX("$scenarioMemberListStr","$versionMember")																										
													FIX(&amp;OEP_CurrYr)	
														FIX(@LEVMBRS("$lineItemDimName",0),@LEVMBRS("Period",0))
															$coreCurrencyScript
														ENDFIX;
														FIX("$ReportingCurrency",&amp;OEP_CurrPeriod:&amp;OEP_FcstStartPeriod,&amp;OEP_CurrYrPeriodRange)
														 "OCF_Opening Balance" (															
																IF (NOT @ISMBR(&amp;OEP_CurrPeriod))
																	"OCF_Opening Balance"= @PRIOR("OCF_Opening Balance")+( @PRIOR("OCF_Operating Cash Inflow")+ @PRIOR("OCF_Financing Cash Inflows")+@PRIOR("OCF_Investing Cash Inflows"))-( @PRIOR("OCF_Operating Cash Outflow")+ @PRIOR("OCF_Financing Cash Outflows")+ @PRIOR("OCF_Investing Cash Outflows")+@PRIOR("OCF_Cash Outflows for Fixed Assets"));
																ENDIF;
															); 				
														ENDFIX;
													ENDFIX;		
													FIX(&amp;OEP_NextYr)
														FIX(@LEVMBRS("$lineItemDimName",0),@LEVMBRS("Period",0))
															$coreCurrencyScript
														ENDFIX;
														FIX("$ReportingCurrency",&amp;OEP_NextYrPeriodRange)
														   "OCF_Opening Balance"(
															@CALCMODE(BottomUp);
																IF ( @ISMBR("$startPeriod"))									
																	"OCF_Opening Balance"= "OCF_Opening Balance"->&amp;OEP_CurrYr->"$endPeriod"+( "OCF_Operating Cash Inflow"->&amp;OEP_CurrYr->"$endPeriod"+ "OCF_Financing Cash Inflows"->&amp;OEP_CurrYr->"$endPeriod"+"OCF_Investing Cash Inflows"->&amp;OEP_CurrYr->"$endPeriod")-( "OCF_Operating Cash Outflow"->&amp;OEP_CurrYr->"$endPeriod"+ "OCF_Financing Cash Outflows"->&amp;OEP_CurrYr->"$endPeriod"+ "OCF_Investing Cash Outflows"->&amp;OEP_CurrYr->"$endPeriod"+ "OCF_Cash Outflows for Fixed Assets"->&amp;OEP_CurrYr->"$endPeriod");
																else
																	"OCF_Opening Balance"= @PRIOR("OCF_Opening Balance")+( @PRIOR("OCF_Operating Cash Inflow")+ @PRIOR("OCF_Financing Cash Inflows")+@PRIOR("OCF_Investing Cash Inflows"))-( @PRIOR("OCF_Operating Cash Outflow")+ @PRIOR("OCF_Financing Cash Outflows")+ @PRIOR("OCF_Investing Cash Outflows")+@PRIOR("OCF_Cash Outflows for Fixed Assets"));
																ENDIF;
																); 
														ENDFIX;		
													ENDFIX;	
												 ENDFIX;
											 
								""" 								
								cscript.append(calcString)
							}
							
							if (chkEntityIsFixParallel == true)
							{
								calcString="""										
											ENDFIXPARALLEL;	
										"""	
							}
							else
							{
							 calcString="""										
											ENDFIX;	
										"""	
							}			
							cscript.append(calcString)			
				}
		   } 
		    scenarioMemberListStr=scenarioMembers.join('","')
		   calcString ="""
						ENDFIX
						FIX($entityValue,"$versionMember","$scenarioMemberListStr",&amp;OEP_PriorYr,&amp;OEP_CurrYr,&amp;OEP_NextYr,@Relative("Input Currencies",0),@Relative("Reporting Currencies",0),@LEVMBRS("$lineItemDimName",0))
						 @IDESCENDANTS("OEP_Total $prjDimName");
						ENDFIX;
					ENDFIX;	
						"""
		   cscript.append(calcString) 	 
		 if (chkValidEntityList == true )
         {			
		  return cscript.toString();
		  
		 }
		 else
		 {
		 return ;
		 }	
		 
	}
			
