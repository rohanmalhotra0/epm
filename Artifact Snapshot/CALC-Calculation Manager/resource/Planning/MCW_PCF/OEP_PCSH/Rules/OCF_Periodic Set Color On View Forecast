<?xml version = '1.0' encoding = 'UTF-8'?>
<HBRRepo><variables/><rulesets/><rules><rule id="1" name="OCF_Periodic Set Color On View Forecast" product="Planning"><property name="application">MCW_PCF</property><property name="plantype">OEP_PCSH</property><property name="seeded">true</property><script type="groovy">					/*
					Purpose: This rule is invoked from the view forecast by method form. This rule changes the background colour of cells where data is matching to Forecast.
							 This form is used to show the blended forecast.
							 1) Fetches the data values of various methods and compares them with the Forecasted member value. 
							 2) if the number matches with Forecast Value, assigns a background colour to the cell of each method.
							 3) The rule allows the OCF_Adjustments row to be editable.
					*/
					def weeklyData=new HashMap&lt;String, Double>()
					operation.grid.dataCellIterator('OCF_Forecasted').each {it ->
					   weeklyData.put(it.getPeriodName(),it.getData())					 
						}					
					operation.grid.dataCellIterator ('OCF_Smart Drivers','OCF_Driver','OCF_Trend','OCF_Statistical Prediction','OCF_Machine Learning Prediction','OCF_Short Term Machine Learning Prediction','OCF_Manual Input','OCF_Forecasted').each {it ->
							if(weeklyData.containsKey(it.getPeriodName())) 
							{
							  if (weeklyData.get(it.getPeriodName()) == it.getData()  )
							  {
								if (it.getData()!=0.0) 	it.setBgColor(11119017);
							  }
							}
						}	

                    operation.grid.dataCellIterator('OCF_Adjustments').each {					  
					it.setForceEditable(true);
						}						
			</script></rule></rules><components/><deployobjects><deployobject product="2" application="mcw_pcf" plantype="oep_pcsh" obj_id="1" obj_type="1" name="OCF_PERIODIC SET COLOR ON VIEW FORECAST"/></deployobjects></HBRRepo>