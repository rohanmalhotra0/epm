				 /***
				 *  Calculate Tax installment based on the commulative  tax input. Rule calculates based on the installment percentage on the data of commulative tax then subtracts previously paid tax.
				 * 	@param  List of Tax installments.					 
				 * 	@return  - returns tax calulation script.
				 *  Additonal Notes :
				 *  	1) 1st Installment is computed on instalment due date , percentage of annual amount as of that date
				 *		2) 2nd installment is computed on instalment due date , percentage of annual amount as of this date - tax computed from previous installment.
				 *		3) 3rd installment is computed on instalment due date , percentage of annual amount as of this date - tax computed from previous installment.
				 *		4) 4th installment is computed on instalment due date , percentage of annual amount as of this date - tax computed from previous installment.
				 **/

				def calculateTaxInstallements(List&lt;String> taxInstallementsList)
							  {
							  
							  def taxCalcScript = new StringBuilder()	
							  def calcString 
							  int counter=0;
							  taxInstallementsList.each{ it ->
								
								 def installment='"'+it.toString()+'"';
								  if (counter==0)
								  {
							  calcString ="""
															IF (("No Currency"->$installment->"OCF_Due Date">="OCF_Tp_date") and ("No Currency"->$installment->"OCF_Due Date"&lt;="OCF_Tp_EndDate"))
																		CumulativeTaxPercentage=CumulativeTaxPercentage+"No Currency"->$installment->"OCF_Percentage";
																		$installment="OCF_Cash Drivers" * CumulativeTaxPercentage;   
																		CumulativeAlloctedTax=CumulativeAlloctedTax+$installment;
															ENDIF;
									 """
								taxCalcScript.append(calcString)
								counter=counter+1;
								}
								else
								{
								  calcString ="""
															IF (("No Currency"->$installment->"OCF_Due Date">="OCF_Tp_date") AND ("No Currency"->$installment->"OCF_Due Date"&lt;="OCF_Tp_EndDate") )
																		CumulativeTaxPercentage=CumulativeTaxPercentage+"No Currency"->$installment->"OCF_Percentage";
																		$installment="OCF_Cash Drivers" * CumulativeTaxPercentage - CumulativeAlloctedTax;   
																		CumulativeAlloctedTax=CumulativeAlloctedTax+$installment;
															ENDIF;
									 """
								taxCalcScript.append(calcString)   
								 counter=counter+1;
								}
								

