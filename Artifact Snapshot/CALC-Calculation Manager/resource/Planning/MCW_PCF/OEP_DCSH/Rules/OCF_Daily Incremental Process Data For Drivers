				String calcString;
				String fixCategory,aggCategory;
				String flexDim1Name = "flexDimension1";
				String flexDim2Name = "flexDimension2";
				String flexDim3Name = "flexDimension3";
				String currencyDimName="Currency";
				String partyDimName="Party";
				String buDimName="Business Unit";
				String prjDimName="Category";
				String bankDimName="Bank";
				String forecastMethodDimName = "Forecast Method";
				String yearDimName="Years"
				String lineItemDimName="Line Item"
				String entityDimName = "Entity";
                String variableDeclarationForFixPrarallel ="";
                String variableDeclaration ="";
				String startFixParallel =""
				String endFixParallel ="";
				def isflexDim1Enabled = "NoDirectTaxflexdim1" == "No flexDimension1"			
				def isflexDim2Enabled = "NoDirectTaxflexdim2" == "No flexDimension2"				
				def isflexDim3Enabled = "NoDirectTaxflexdim3" == "No flexDimension3"
				def isPartyEnabled = "No Party" == "No Party"
				def isBuEnabled = "No Business Unit" == "No Business Unit"
				def isPrjEnabled = "No Category" == "No Category"							
