		 * 	@return  - returns driver copy script.
		 *  Additonal Notes :
		 **/
			String getDriverCopyScript(List&lt;String> drivers,String noBankMember)
			{
					def driverCalcScript = new StringBuilder()        
						 
					drivers.eachWithIndex{ it ,i ->
					 def driver='"'+it.toString()+'"';
						def calcString ="""
													 DATACOPY $driver to "OCF_Forecasted";
									"""
					   driverCalcScript.append(calcString);          
					   
					 }
					driverCalcScript.append('"'+noBankMember+'"(\n');
					driverCalcScript.append("		@CALCMODE(BOTTOMUP);\n");   
					driverCalcScript.append ('		"OCF_Forecasted"="'+drivers.join('"+"')+'";\n')
					driverCalcScript.append ('		)\n');
				return driverCalcScript
			}
		
