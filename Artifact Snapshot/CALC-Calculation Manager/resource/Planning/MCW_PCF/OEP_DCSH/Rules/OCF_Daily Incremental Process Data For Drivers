		/***
		 *  This method generates script to copy data from forecast methods into final forecast method based on the set configruation settings.
		 * 	@param  cube name, Scenario ,version and Entity members , list of line items, form context on addtional dimensions.					 
		 * 	@return  - returns script that copies numbers from  forecast methods in to final forecast method.
		 *  Additonal Notes :
		 *			1. Prefered Method , Time range is stored any member combination of dimension. 
					2. Copies the data from All methods in to Forecast member to create blocks.
					3. Pulls the time range and methods in to variables.
					4. For each time period check method selected and copies corresponding value in to forecast method.
					5. Add time range to "OEP_Period Number" to check if periods falls in the range or not.
					5. Rolling forecast range falls in to multiple years. system ensures to copies the right forecast member in to final forecast.
		 **/
		String populateFinalForecastMethod(Cube cashFlowCube,String scenarioMember,String versionMember,String entityMember,String lineItemsMemberGroup,List&lt;String> fixMembers)
		{
			String calcScript,startPeriod,endPeriod,periodRollup,prefMethod1Script,prefMethod2Script,prefMethod3Script;
			def isWeeklyEnabled = "Monthly" == "Weekly"
			def isMonthlyEnabled = "Monthly" == "Monthly"	
			List&lt;String> noFixMembers=[];
			String fixMembersJoin, noFixMembersJoin;
			String flexDim1Name = "flexDimension1";
			String flexDim2Name = "flexDimension2";
			String flexDim3Name = "flexDimension3";
			String trendMethod = "No Forecast Method";
			String yearDimName="Years"
			String bankDimName="Bank";		
			String entityDimName = "Entity";
			String currencyDimName="Currency";
			String partyDimName="Party";
			String buDimName="Business Unit";
			String prjDimName="Category"
			String firstYearSmartDriverScript="";
			String secondYearSmartDriverScript="";
			String beginFixScript = "";	
            String endFixScript = "";			
			List&lt;String>  lineItems = getRelativeOfLineItems(lineItemsMemberGroup);			
			String erpMembers = getValidERPLineItems(cashFlowCube) ;			
			if ((lineItemsMemberGroup=="OCF_Total Cash") &amp;&amp; (erpMembers!=""))
			{
				firstYearSmartDriverScript= """
												FIX("$erpMembers",&amp;OEP_CurrYr,&amp;OEP_CurrPeriod:&amp;OEP_FcstStartPeriod)
													Datacopy "OCF_Smart Drivers" to "OCF_Forecasted";								
												ENDFIX;
											"""
				secondYearSmartDriverScript= """
												FIX("$erpMembers"&amp;OEP_NextYr,&amp;OEP_CurrPeriod:&amp;OEP_FcstStartPeriod)
													Datacopy "OCF_Smart Drivers" to "OCF_Forecasted";								
												ENDFIX;
											"""							
			}
			String  lineItemsGroup= lineItems.join(',');
			
			String copyScript=setForecastDataCopy(cashFlowCube);
			Application application = operation.application;				
			if (cashFlowCube.getEssbaseName()=="OEP_PCSH")
			{
				trendMethod="OCF_Trend";
				if (isMonthlyEnabled) periodRollup="YearTotal"	;
				if (isWeeklyEnabled)  periodRollup="OEP_Weekly YearTotal";
			}
			else
			{
				periodRollup="OEP_Daily YearTotal";
			}
			List&lt;String> lstPeriods=application.getDimension("Period",cashFlowCube).getEvaluatedMembers('ILvl0Descendants("'+periodRollup+'")',cashFlowCube).collect{it.toString()};	
			 startPeriod=lstPeriods.first();	
			 endPeriod=lstPeriods.last();			
			String numOfPeriods = getNumberOfYears(cashFlowCube);
			SubstitutionVariable subVariableFcstPeriods=cashFlowCube.getSubstitutionVariable("OEP_NumberOfForecastPeriods");
			String fcstPeriods=subVariableFcstPeriods.getValue();
			if(application.hasDimension(flexDim1Name, cashFlowCube)) noFixMembers.add('"No '+ flexDim1Name +'"')
			if(application.hasDimension(flexDim2Name, cashFlowCube)) noFixMembers.add('"No '+ flexDim2Name +'"') 
			if(application.hasDimension(flexDim3Name, cashFlowCube)) noFixMembers.add('"No '+ flexDim3Name +'"') 
			if(application.hasDimension(prjDimName, cashFlowCube)) noFixMembers.add('"OEP_Any '+ prjDimName +'"') 
			if(application.hasDimension(partyDimName, cashFlowCube)) noFixMembers.add('"OEP_Any '+ partyDimName +'"') 
			if(application.hasDimension(buDimName, cashFlowCube)) noFixMembers.add('"OEP_Any '+ buDimName +'"') 			
			fixMembersJoin=fixMembers.join(",");
			noFixMembersJoin=noFixMembers.join("->")
			prefMethod1Script = setForecastMethod(cashFlowCube,noFixMembersJoin,"OCF_Preferred Method 1",lineItemsMemberGroup);
			prefMethod2Script = setForecastMethod(cashFlowCube,noFixMembersJoin,"OCF_Preferred Method 2",lineItemsMemberGroup);
			prefMethod3Script = setForecastMethod(cashFlowCube,noFixMembersJoin,"OCF_Preferred Method 3",lineItemsMemberGroup);
		   /* if (fixMembers.size() != 0)
			{
				beginFixScript ="""
									Var PrefRang1;
									Var PrefRang2;
									Var PrefRang3;		
									 FIX($entityMember,$scenarioMember,$versionMember,$fixMembersJoin)
									"""
				endFixScript="ENDFIX"	
			}
			else
			{
			   beginFixScript ="";
			   endFixScript=""
			} */
			if (numOfPeriods=="2")
			{
			calcScript="""
								$beginFixScript
								FIX($lineItemsGroup)
								 FIX(&amp;OEP_CurrYr,&amp;OEP_CurrYrPeriodRange)
									$copyScript										
								 ENDFIX;
								 $firstYearSmartDriverScript								 
								 FIX(&amp;OEP_CurrYr,&amp;OEP_CurrYrPeriodRange)
								  CLEARDATA "OCF_Forecasted";
								 ENDFIX;
								 FIX(&amp;OEP_NextYr,&amp;OEP_NextYrPeriodRange)
									$copyScript										
								 ENDFIX;
								 $secondYearSmartDriverScript
								 FIX(&amp;OEP_NextYr,&amp;OEP_NextYrPeriodRange)
								  CLEARDATA "OCF_Forecasted";
								 ENDFIX;
								ENDFIX; 
								FIX($lineItemsGroup,&amp;OEP_CurrYr,&amp;OEP_CurrYrPeriodRange)
									   "OCF_Forecasted"
												(
													@CALCMODE(BOTTOMUP);
													If ("No Currency"->"No Year"->"BegBalance"->$noFixMembersJoin->"OCF_Preferred Range 1" == #MISSING)
														if ("OCF_Period Number"->&amp;OEP_FcstStartPeriod != "OCF_Period Number"->&amp;OEP_CurrPeriod)
															if ("OCF_Period Number"->&amp;OEP_FcstStartPeriod &lt; "OCF_Period Number"->$endPeriod)
																PrefRang1 = "OCF_Period Number"->&amp;OEP_FcstStartPeriod -"OCF_Period Number"->&amp;OEP_CurrPeriod+$fcstPeriods;
															else
																PrefRang1 = "OCF_Period Number"->&amp;OEP_FcstStartPeriod +"OCF_Period Number"->$endPeriod -"OCF_Period Number"->&amp;OEP_CurrPeriod+$fcstPeriods;
															ENDIF;
														ELSE
															PrefRang1=$fcstPeriods;
														ENDIF;
													ELSE													
														PrefRang1="No Currency"->"No Year"->"BegBalance"->$noFixMembersJoin->"OCF_Preferred Range 1" ;
													ENDIF;
													PrefRang2="No Currency"->"No Year"->"BegBalance"->$noFixMembersJoin->"OCF_Preferred Range 2" ;
													PrefRang3="No Currency"->"No Year"->"BegBalance"->$noFixMembersJoin->"OCF_Preferred Range 3" ;
													IF (("OCF_Period Number" ) >= "OCF_Period Number"->&amp;OEP_FcstStartPeriod-1)
														IF( "OCF_Period Number"  &lt;= ("OCF_Period Number"->&amp;OEP_FcstStartPeriod +PrefRang1-1)) 
															$prefMethod1Script													
														ELSEIF(( "OCF_Period Number"  > ("OCF_Period Number"->&amp;OEP_FcstStartPeriod +PrefRang1-1 )) AND ( "OCF_Period Number"  &lt;= ("OCF_Period Number"->&amp;OEP_FcstStartPeriod +PrefRang2-1))) 
															$prefMethod2Script												
														ELSEIF(( "OCF_Period Number"  > ("OCF_Period Number"->&amp;OEP_FcstStartPeriod +PrefRang2-1 )) AND ( "OCF_Period Number"  &lt;= ("OCF_Period Number"->&amp;OEP_FcstStartPeriod +PrefRang3-1))) 
															$prefMethod3Script
														ENDIF;
													ENDIF;
												
												);								
								ENDFIX;
								FIX($lineItemsGroup,&amp;OEP_NextYr,&amp;OEP_NextYrPeriodRange)
									   "OCF_Forecasted"
