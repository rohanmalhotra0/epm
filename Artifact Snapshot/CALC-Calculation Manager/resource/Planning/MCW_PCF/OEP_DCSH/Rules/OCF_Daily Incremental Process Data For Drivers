				String nextYear(String currentYear, List&lt;String> yearsList)
				 {
				  boolean chkCurrentMbr=false;
				  String mbrName
					yearsList.each{ it->
						if (chkCurrentMbr==true)
						{
						   
						 mbrName=it.toString();
						 chkCurrentMbr=false;
						}
