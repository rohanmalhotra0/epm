									ENDFIX
									$calcCopyString
									$calcOpenBal
								$catEndFix	
								FIX("$versionMember","$yearOne","$yearTwo",@Relative("OCF_Total Fixed Asset Payments",0),@Relative("$periodRollup",0),"OCF_Opening Balance",@Relative("OCF_Cash Flow Metrics",0),@Relative("OCF_All Forecast Method",0),@Relative("OCF_Total Forecasted Cash",0))	
									$aggCategory
								ENDFIX	
								$endFixParallel
							  ENDFIX
						   $entityEndStr   
					 """ 
					 cscript.append(calcString);
