		**/
		  String  calculateOpeningBalance(String noFixMembersJoin,String startPeriod,String endPeriod)
		  {
			
				String calcString =	""" 
									FIX(&amp;OEP_PriorYr,$startPeriod:$endPeriod)										  
									 "OCF_Opening Balance"(
										@CALCMODE(BOTTOMUP);
