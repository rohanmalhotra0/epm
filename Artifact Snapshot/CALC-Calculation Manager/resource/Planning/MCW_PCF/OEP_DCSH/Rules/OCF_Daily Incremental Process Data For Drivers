		* @Param : Cashflow cube 
		* @return : Current Period.
		*/
			
			String getFirstForecastPeriod(Cube cashFlowCube)
			{
					SubstitutionVariable subVariableFirstForecastPeriod=cashFlowCube.getSubstitutionVariable("OEP_CurrPeriod");
					String firstForecastPeriod=subVariableFirstForecastPeriod.getValue();
					return firstForecastPeriod;					
			}				
		/***
		 *  Retuns first periods from list of Period members.
		 * 	@param  PeriodDimension, predictate is member function that give list of members , Cash cube names 					 
		 * 	@return  - returns first period.		 
		 **/
			String getFirstPeriod(PeriodDimension periodDim, String Predicate, Cube cashCube)
			{
				List&lt;Member> PeriodMbrs=periodDim.getEvaluatedMembers(Predicate,cashCube);
				return PeriodMbrs[0]; 
			}
			
		/***
		 *  Retuns next period of current period by looking up in to list of period members.
		 * 	@param  PeriodDimension, predictate is member function that give list of members , Cash cube name,current period and next period. 					 
		 * 	@return  - returns first period.		 
		 **/
			String getNextPeriodFromCurrentPeriod(PeriodDimension periodDim, String Predicate, Cube cashCube,String currPeriod,int NumberofPeriods)
			{
				int positionOfCurrPeriod = 0 ;
				String nextPeriod; 
			  List&lt;Member> PeriodMbrs=periodDim.getEvaluatedMembers(Predicate,cashCube)
				  PeriodMbrs.eachWithIndex {it, i ->
					  String strPeriod=it.toString();
					  if (strPeriod.equals(currPeriod) )
						{
						   positionOfCurrPeriod=i; 
						} 
						if ((positionOfCurrPeriod==0)  &amp;&amp; (i == positionOfCurrPeriod+NumberofPeriods-1 ))
						{
						 nextPeriod=strPeriod;
						}
						else if ((positionOfCurrPeriod!=0) &amp;&amp; (i == positionOfCurrPeriod+NumberofPeriods ))
						{
						  nextPeriod=strPeriod;	
						}
					}
			 return nextPeriod;

