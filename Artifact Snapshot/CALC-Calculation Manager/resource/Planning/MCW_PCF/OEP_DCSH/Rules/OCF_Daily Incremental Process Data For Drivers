				if (fixParallelDim==flexDim1Name)  flexDim1Name="NoDimension";
				if (fixParallelDim==flexDim2Name) flexDim2Name="NoDimension";				
				if (fixParallelDim==flexDim3Name) flexDim3Name="NoDimension";
				populateFixMembersPostDimCheckForFlexDim(cashFlowCube,flexDim1Name,flexDim1Member,isflexDim1Enabled,fixMembers);
				populateFixMembersPostDimCheckForFlexDim(cashFlowCube,flexDim2Name,flexDim2Member,isflexDim2Enabled,fixMembers);
				populateFixMembersPostDimCheckForFlexDim(cashFlowCube,flexDim3Name,flexDim3Member,isflexDim3Enabled,fixMembers);
				populateFixMembersPostDimCheckForStdDim(cashFlowCube,partyDimName,partyMember,isPartyEnabled,fixMembers);
				populateFixMembersPostDimCheckForStdDim(cashFlowCube,buDimName,buMember,isBuEnabled,fixMembers);
				fixCategory=getFixOfCategoryDimension(cashFlowCube,prjDimName,prjMember,isPrjEnabled)
				aggCategory=getAggOfCategoryDimension(cashFlowCube,prjDimName,prjMember,isPrjEnabled)
				catStartFix= """ FIX($fixCategory) """
				catEndFix =""" ENDFIX """
				addCurrency(fixMembers,currencyMember);
				addNoCurrency(noFixMembers);
				if(operation.application.hasDimension(bankDimName, cashFlowCube))
				{
				   noFixMembers.add('"OEP_Any '+bankDimName+'"'); 
				   fixMembers.add('"OEP_Any '+bankDimName+'"');
				}
				noFixMembersJoinStr=noFixMembers.join("->");
				fixMembersJoin=fixMembers.join(",");
				entityBeginStr =(chkEntityIsFixParallel==true) ? fixParalleFixStmt : "FIX($entityMember)"
				entityEndStr =(chkEntityIsFixParallel==true) ? "ENDFIXPARALLEL" : "ENDFIX"               
				String calcInstallments= calculateTaxInstallements(taxInstallements);
				String clrInstallments=clearTaxInstallements(taxInstallements);
				if(chkEntityIsFixParallel == true)
				{
				variableDeclarationForFixPrarallel="""
							ThreadVar CumulativeTaxPercentage;
							ThreadVar CumulativeAlloctedTax;
							$varialStringForFixParallel
				"""
				}
				else
                {
				if (!operation.application.hasDimension(fixParallelDim, cashFlowCube) )
					  {		
						variableDeclaration="""
									Var CumulativeTaxPercentage;
									Var CumulativeAlloctedTax;
									$variableString	
						"""
					 }
                }
				if(operation.application.hasDimension(fixParallelDim, cashFlowCube) &amp;&amp; chkEntityIsFixParallel==false )
				  {
					 if (chkCategoryFixParallel==true)
					 {
						catStartFix="""$fixParalleFixStmt					 
										ThreadVar CumulativeTaxPercentage;
										ThreadVar CumulativeAlloctedTax;
										$varialStringForFixParallel	
								      """	
						 catEndFix = """ ENDFIXPARALLEL """
					 }
					 else
					 {
						 startFixParallel="""$fixParalleFixStmt
										ThreadVar CumulativeTaxPercentage;
										ThreadVar CumulativeAlloctedTax;
										$varialStringForFixParallel	
								      """	
						 endFixParallel=""" ENDFIXPARALLEL;   """
					}
				  }	  
				   finalCalc="""																		
								  "OCF_Cash Drivers" (
										@CALCMODE(BOTTOMUP);
											 IF(@ISMBR("Begbalance"))
												   CumulativeTaxPercentage=0;
												   CumulativeAlloctedTax=0;
											 ENDIF;
											$calcInstallments
									   )
											  """
					  
				 if (numOfPeriods=="2")
				  {
				  calcString="""
                  		   SET UPDATECALC OFF;
						   SET AGGMISSG ON;
						   $variableDeclaration		
						   $entityBeginStr
                           $variableDeclarationForFixPrarallel
						   FIX($scenarioMember,$fixMembersJoin,$versionMember)
								$startFixParallel
								$catStartFix
									FIX(@relative("OCF_Total Direct Tax Payment",0),$yearOne,$yearTwo,"Begbalance",$startPeriod:$endPeriod)
											 $clrInstallments;
									ENDFIX;
									FIX("$yearOne","$yearTwo",@Relative("OCF_Total Direct Tax Payment",0),"Begbalance",$startPeriod:$endPeriod)
										 $finalCalc										
									ENDFIX 
										$calcCopyString
										$calcOpenBal	
								$catEndFix
								FIX("$versionMember","$yearOne","$yearTwo",@Relative("OCF_Total Direct Tax Payment",0),"Begbalance",$startPeriod:$endPeriod,"OCF_Opening Balance",@Relative("OCF_Cash Flow Metrics",0),@Relative("OCF_All Forecast Method",0),@Relative("OCF_Total Forecasted Cash",0))
									$aggCategory
								ENDFIX	
								$endFixParallel
						   ENDFIX
						   $entityEndStr
					 """
					 cscript.append(calcString)
				 }
				else
				  {
				   calcString="""
						   SET UPDATECALC OFF;
						   SET AGGMISSG ON;
						   $variableDeclaration			
						   $entityBeginStr	
                           $variableDeclarationForFixPrarallel
							 FIX($scenarioMember,$fixMembersJoin,$versionMember)
								$startFixParallel
								$catStartFix
									FIX(@relative("OCF_Total Direct Tax Payment",0),$yearOne,"Begbalance",$startPeriod:$endPeriod)
										$clrInstallments;
									ENDFIX; 								  
									FIX("$yearOne",@Relative("OCF_Total Direct Tax Payment",0),$startPeriod:$endPeriod)
										  $finalCalc										  
									ENDFIX
									$calcCopyString
									$calcOpenBal									  
								$catEndFix
								FIX("$versionMember","$yearOne",@Relative("OCF_Total Direct Tax Payment",0),"Begbalance",$startPeriod:$endPeriod,"OCF_Opening Balance",@Relative("OCF_Cash Flow Metrics",0),@Relative("OCF_All Forecast Method",0),@Relative("OCF_Total Forecasted Cash",0))
									$aggCategory
								ENDFIX
								$endFixParallel	
							ENDFIX;	
							  
						   $entityEndStr
					 """
						cscript.append(calcString)
				  }					
				return cscript.toString()
				
	}	
</script><template_wizard/><template_prompts><restricted_prompt name="Application Type" type="Application Type" isPrompt="no"><property name="is_system">true</property><restricted_prompt_item><property name="prompt">Is Generic</property><property name="value">GENERAL</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is PFP</property><property name="value">PROJECT</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is PSB</property><property name="value">PSB</property></restricted_prompt_item></restricted_prompt><restricted_prompt name="Application" type="Application" isPrompt="no"><property name="is_system">true</property><value>Is Single Currency</value><restricted_prompt_item><property name="prompt">Is Multi Currency</property><property name="value">multi</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is Single Currency</property><property name="value">single</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is Simple Currency</property><property name="value">simple</property></restricted_prompt_item></restricted_prompt><template_slice_prompt name="UpperPOV" type="Member Range" isPrompt="false"><property name="is_system">true</property></template_slice_prompt><restricted_prompt name="Essbase Mode" type="Essbase Mode" isPrompt="no"><property name="is_system">true</property><restricted_prompt_item><property name="prompt">Is Hybrid</property><property name="value">Hybrid</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is NonHybrid</property><property name="value">NonHybrid</property></restricted_prompt_item></restricted_prompt></template_prompts></template><template custom="yes" id="7" name="OCF_DPO_GT" product="Planning"><property name="application">MCW_PCF</property><property name="plantype">OEP_DCSH</property><property name="seeded">true</property><property name="standAlone">false</property><script type="groovy">	  /***
		 * Calculate DPO Payments for line items applying the average DPO of same period . if same days average period is not available, then applies global average DPO.   .
		 * @param cube, scenario, version, entity will be passed from form context.
		 * @param  startperiod and end periods, Daily, weekly and Monthly  first and last period of corresponding period dimension.
		 * @param fixParallelDim  - the name of the dimension on which fix parallel to be applied.
		 * @return  - returns calculation script to compute DPO, populate DPO numbers to rolling forecast screen based on forecast method settings, and calculation logic to compute opening balance.
		 * Additional Notes:
		 *				1. Checks if the request is coming from grid, Data management ( Member names passed as a list), or Rules card and generates out fix accordingly
		 *				2. Rules generate code based on the fix parallel dimension. If entity is the fix parallel dimension, outer fix will have entity dimension with fix parallel  
		 *					whereas other dimensions will have fix parallel inside out fix.
		 *				3. NumberOfYears sub variable is used if code can be generated for single year or 2 years.
		 *				4. OCF_Calculated Cashflow member is used to compute DSO and DPO.
		 *				5. Clears the previously  posted DPO number before re-computing the new DPO based on the new number
		 *				6. If we have already posted DPO number using previous  DPO days, new dso number will be added to existing one.
		 *				7. Finally, it copies the DPO number based on the forecast method setting to Forecast member and recomputes opening balance.	
		 **/
	  String calculateDPO(Cube cashFlowCube,String scenarioMember,String versionMember,String entityMember,String startPeriod,String endPeriod,String fixParallelDim, int totalPeriods, String periodRollup,String flexDim1Member,String flexDim2Member,String flexDim3Member,String partyMember,String buMember,String prjMember,String currencyMember)
		{
