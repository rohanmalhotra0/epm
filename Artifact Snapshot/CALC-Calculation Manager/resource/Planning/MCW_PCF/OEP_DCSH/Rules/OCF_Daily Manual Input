														ELSEIF(( "OCF_Period Number"  > ("OCF_Period Number"->&amp;OEP_FcstStartPeriod +PrefRang2-1 )) AND ( "OCF_Period Number"  &lt;= ("OCF_Period Number"->&amp;OEP_FcstStartPeriod +PrefRang3-1))) 
															$prefMethod3Script	
