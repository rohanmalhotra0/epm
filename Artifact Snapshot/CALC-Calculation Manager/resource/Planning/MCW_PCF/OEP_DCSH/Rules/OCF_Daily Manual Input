		/***
		 *  Retuns first periods from list of Period members.
		 * 	@param  PeriodDimension, predictate is member function that give list of members , Cash cube names 					 
		 * 	@return  - returns first period.		 
		 **/
			String getFirstPeriod(PeriodDimension periodDim, String Predicate, Cube cashCube)
			{
				List&lt;Member> PeriodMbrs=periodDim.getEvaluatedMembers(Predicate,cashCube);
				return PeriodMbrs[0]; 
			}
			
		/***
		 *  Retuns next period of current period by looking up in to list of period members.
		 * 	@param  PeriodDimension, predictate is member function that give list of members , Cash cube name,current period and next period. 					 
		 * 	@return  - returns first period.		 
		 **/
			String getNextPeriodFromCurrentPeriod(PeriodDimension periodDim, String Predicate, Cube cashCube,String currPeriod,int NumberofPeriods)
			{
				int positionOfCurrPeriod = 0 ;
				String nextPeriod; 
			  List&lt;Member> PeriodMbrs=periodDim.getEvaluatedMembers(Predicate,cashCube)
				  PeriodMbrs.eachWithIndex {it, i ->
					  String strPeriod=it.toString();
					  if (strPeriod.equals(currPeriod) )
						{
						   positionOfCurrPeriod=i; 
						} 
						if ((positionOfCurrPeriod==0)  &amp;&amp; (i == positionOfCurrPeriod+NumberofPeriods-1 ))
						{
						 nextPeriod=strPeriod;
						}
						else if ((positionOfCurrPeriod!=0) &amp;&amp; (i == positionOfCurrPeriod+NumberofPeriods ))
						{
						  nextPeriod=strPeriod;	
						}
					}
			 return nextPeriod;

			}
		/***
		 *  Retuns Forecast method name based on the smart lis vaule.
		 * 	@param  index values of the method 					 
		 * 	@return  - returns method name.
		 *  Additonal Notes :
		 **/
			String getMethodName( def indexValue )
			{
			 String methodName
				 if (indexValue==1.0)  methodName="OCF_Driver";
				 if (indexValue==2.0)  methodName="OCF_Smart Drivers";
				 if (indexValue==3.0)  methodName="OCF_Statistical Prediction";
				 if (indexValue==4.0)  methodName="OCF_Machine Learning Prediction";
				 if (indexValue==5.0)  methodName="OCF_Manual Input";
				 if (indexValue==6.0)  methodName="OCF_Trend";
				 if (indexValue==7.0)  methodName="OCF_Short Term Machine Learning Prediction";				 
					return methodName;
			}
			
		/***
		 *  Generates copy script to copy data from individual forecast method  in to final forecast method based on set forecast method settings.
		 * 	@param  List of Drivers and , No bank member to fix copy script.					 
		 * 	@return  - returns driver copy script.
		 *  Additonal Notes :
		 **/
			String getDriverCopyScript(List&lt;String> drivers,String noBankMember)
			{
					def driverCalcScript = new StringBuilder()        
						 
					drivers.eachWithIndex{ it ,i ->
					 def driver='"'+it.toString()+'"';
						def calcString ="""
													 DATACOPY $driver to "OCF_Forecasted";
									"""
					   driverCalcScript.append(calcString);          
					   
					 }
					driverCalcScript.append('"'+noBankMember+'"(\n');
					driverCalcScript.append("		@CALCMODE(BOTTOMUP);\n");   
					driverCalcScript.append ('		"OCF_Forecasted"="'+drivers.join('"+"')+'";\n')
					driverCalcScript.append ('		)\n');
				return driverCalcScript
			}
		
		/***
		* Splits thee string converts in to Realtive String	
		**/
		List&lt;String>  getRelativeOfLineItems (String listOfLineItems)
		{
		  String [] lstLineItems =listOfLineItems.split(',')		 
		  List&lt;String> lstRelativeLineItems=[];
			 for( String values : lstLineItems )
			 lstRelativeLineItems.add('@Relative("'+values+'",0)')
			 return lstRelativeLineItems;
		}		
		/***
		This method generates copy script based on the presence of member .  Copy script creates the blocks to forecasted members. based on the availablity of the source line item.		
		***/
		String setForecastDataCopy(Cube cashFlowCube)
		{
		 
			 StringBuilder copyScript = new StringBuilder();
			 Dimension fcstMethodDimension=operation.application.getDimension("Forecast Method",cashFlowCube);
			 if (fcstMethodDimension.hasMember("OCF_Smart Drivers",cashFlowCube))	copyScript.append('DATACOPY "OCF_Smart Drivers" to "OCF_Forecasted";\n');
			 if (fcstMethodDimension.hasMember("OCF_Pay Term1",cashFlowCube))	copyScript.append('									DATACOPY "OCF_Pay Term1" to "OCF_Forecasted";\n');
			 if (fcstMethodDimension.hasMember("OCF_Calculated Cashflow",cashFlowCube))	copyScript.append('									DATACOPY "OCF_Calculated Cashflow" to "OCF_Forecasted";\n');
			 if (fcstMethodDimension.hasMember("OCF_Tax Installment1",cashFlowCube))	copyScript.append('									DATACOPY "OCF_Tax Installment1" to "OCF_Forecasted";\n');
			 if (fcstMethodDimension.hasMember("OCF_Machine Learning Prediction",cashFlowCube))	copyScript.append('									DATACOPY "OCF_Machine Learning Prediction" to "OCF_Forecasted";\n');
			 if (fcstMethodDimension.hasMember("OCF_Statistical Prediction",cashFlowCube))	copyScript.append('									DATACOPY "OCF_Statistical Prediction" to "OCF_Forecasted";\n');
			 if (fcstMethodDimension.hasMember("OCF_Trend",cashFlowCube))	copyScript.append('									DATACOPY "OCF_Trend" to "OCF_Forecasted";\n');
			 if (fcstMethodDimension.hasMember("OCF_Short Term Machine Learning Prediction",cashFlowCube))	copyScript.append('						DATACOPY "OCF_Short Term Machine Learning Prediction" to "OCF_Forecasted";\n');			 
			 if (fcstMethodDimension.hasMember("OCF_Manual Input",cashFlowCube))	copyScript.append('									DATACOPY "OCF_Manual Input" to "OCF_Forecasted";\n');		  
			return copyScript.toString();
		
		}
