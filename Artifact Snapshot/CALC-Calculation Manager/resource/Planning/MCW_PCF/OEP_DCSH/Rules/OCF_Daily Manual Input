															$prefMethod2Script													
														ELSEIF(( ("OCF_Period Number"+ "OCF_Period Number"->$endPeriod)  > ("OCF_Period Number"->&amp;OEP_CurrYr->&amp;OEP_FcstStartPeriod +PrefRang2-1 )) AND ( ("OCF_Period Number"+ "OCF_Period Number"->$endPeriod)  &lt;= ("OCF_Period Number"->&amp;OEP_CurrYr->&amp;OEP_FcstStartPeriod +PrefRang3-1))) 
															$prefMethod3Script
														ENDIF;
												);								
								ENDFIX;
						 $endFixScript;
				
				
				"""
			
			}
			else
			{
			calcScript="""
								$beginFixScript	
								FIX($lineItemsGroup,&amp;OEP_CurrYr,&amp;OEP_CurrYrPeriodRange)
									$copyScript									
								ENDFIX;
								$firstYearSmartDriverScript
								FIX($lineItemsGroup,&amp;OEP_CurrYr,&amp;OEP_CurrYrPeriodRange)
