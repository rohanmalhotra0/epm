					 **/
  	   				def payTermCalculation(String yearOne, String yearTwo,String noFixMembers, List&lt;String> payTermList,String nextPeriod,String beginPeriod, String lastPeriod,String srcForecastMethod,int totalPeriods)
					  {
					  
						def variableList = new StringBuilder()	
