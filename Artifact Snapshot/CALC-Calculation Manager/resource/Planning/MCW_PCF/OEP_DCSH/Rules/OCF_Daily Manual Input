		/***
		*  This method checks for existing of member and generates code to set default driver method in case users do not set forecast method in form.
		*  User forecast method and range will override default method.
		***/
		String setForecastMethod(Cube cashFlowCube,String noFixMembersJoin, String preferedMethod,String lineItemsMemberGroup)
		{
			 String cscript,endScript;
			 StringBuilder fcstScript = new StringBuilder();
			 Dimension fcstMethodDimension=operation.application.getDimension("Forecast Method",cashFlowCube);
			 Dimension dimLineItem=operation.application.getDimension(DimensionType.ACCOUNT,cashFlowCube);
			
			  if (fcstMethodDimension.hasMember("OCF_Driver",cashFlowCube))
			  {
				  cscript="""
																IF("No Currency"->"No Year"->"BegBalance"->$noFixMembersJoin->"$preferedMethod"==1)  
																	  "OCF_Forecasted"="OCF_Driver";
						 """
				  fcstScript.append(cscript);
			  }
			  if (fcstMethodDimension.hasMember("OCF_Smart Drivers",cashFlowCube))
			  {
				  cscript="""										ELSEIF("No Currency"->"No Year"->"BegBalance"->$noFixMembersJoin->"$preferedMethod"==2)  
																	  "OCF_Forecasted"="OCF_Smart Drivers";
						 """
				  fcstScript.append(cscript);
			   
			  }
			  if (fcstMethodDimension.hasMember("OCF_Statistical Prediction",cashFlowCube))
			  {
				  cscript="""										ELSEIF("No Currency"->"No Year"->"BegBalance"->$noFixMembersJoin->"$preferedMethod"==3)  
																		"OCF_Forecasted"="OCF_Statistical Prediction";
						 """
				  fcstScript.append(cscript);			  
			  }
			   if (fcstMethodDimension.hasMember("OCF_Machine Learning Prediction",cashFlowCube))
			  {
			    cscript="""										ELSEIF("No Currency"->"No Year"->"BegBalance"->$noFixMembersJoin->"$preferedMethod"==4)  
																		"OCF_Forecasted"="OCF_Machine Learning Prediction";
						 """
				  fcstScript.append(cscript);			  
			  }
			   if (fcstMethodDimension.hasMember("OCF_Short Term Machine Learning Prediction",cashFlowCube))
			  {
			    cscript="""										ELSEIF("No Currency"->"No Year"->"BegBalance"->$noFixMembersJoin->"$preferedMethod"==7)  
																		"OCF_Forecasted"="OCF_Short Term Machine Learning Prediction";
						 """
				  fcstScript.append(cscript);			  
			  }			  
			  if (fcstMethodDimension.hasMember("OCF_Manual Input",cashFlowCube))
			  {
			   cscript="""										ELSEIF("No Currency"->"No Year"->"BegBalance"->$noFixMembersJoin->"$preferedMethod"==5)  
																		"OCF_Forecasted"="OCF_Manual Input";
						 """
				  fcstScript.append(cscript);			 
			  }
			  if (fcstMethodDimension.hasMember("OCF_Trend",cashFlowCube))
			  {
			   cscript="""										ELSEIF("No Currency"->"No Year"->"BegBalance"->$noFixMembersJoin->"$preferedMethod"==6)  
																		"OCF_Forecasted"="OCF_Trend";
						 """
				  fcstScript.append(cscript);			  
			  }
			  
			  if ((dimLineItem.hasMember("OCF_Receivables Invoices",cashFlowCube)==true) ||  (dimLineItem.hasMember("OCF_Payables Invoices",cashFlowCube)==true) ||  (dimLineItem.hasMember("OCF_Cash Transactions Inflows",cashFlowCube)==true) || (fcstMethodDimension.hasMember("OCF_Driver",cashFlowCube)))
			  {
				cscript="""	 									ELSEIF("No Currency"->"No Year"->"BegBalance"->$noFixMembersJoin->"$preferedMethod"==#MISSING)
						 """
				  fcstScript.append(cscript);
				
				  
			  }
			  if (lineItemsMemberGroup=="OCF_Total Cash")
			  {
				  if (dimLineItem.hasMember("OCF_Receivables Invoices",cashFlowCube)==true)
				  {
					cscript="""	    										IF (@ISMBR("OCF_Customer Receipts") OR @ISMBR("OCF_Receivables Invoices") OR @ISMBR("OCF_Receivables Overdue Invoices") OR @ISMBR("OCF_Unapplied Receipts Offset"))
																				"OCF_Forecasted"="OCF_Smart Drivers";																  
																			ENDIF;
							 """
					  fcstScript.append(cscript);			
						
				  }
				  if (dimLineItem.hasMember("OCF_Payables Invoices",cashFlowCube)==true)
				  {
					cscript="""	    										IF (@ISMBR("OCF_Supplier Payments") OR @ISMBR("OCF_Payables Invoices") OR @ISMBR("OCF_Payables Overdue Invoices") OR @ISMBR("OCF_Unapplied Prepayments Offset")) 
																				"OCF_Forecasted"="OCF_Smart Drivers";																  
																			ENDIF;
							 """
					  fcstScript.append(cscript);	
				  }
				   if (dimLineItem.hasMember("OCF_Cash Transactions Inflows",cashFlowCube)==true)
				  {
						cscript="""	    										IF (@ISMBR("OCF_Cash Transactions Inflows") OR @ISMBR("OCF_Cash Transactions Outflows") )
																					"OCF_Forecasted"="OCF_Smart Drivers";																  
																			ENDIF;
							 """
					  fcstScript.append(cscript);		
				  }
				}  
			   if (fcstMethodDimension.hasMember("OCF_Driver",cashFlowCube))
			  {
					cscript="""	    										IF (@ISMBR(@DESCENDANTS("OCF_Driver Groups"))) 
																				"OCF_Forecasted"="OCF_Driver";																  
																		ENDIF;
						 """
				  fcstScript.append(cscript);
			  }
			  
			  fcstScript.append("										ENDIF;")
			  return fcstScript.toString() ;
			  
		}
		/***
		* This method returns processForecast business rule code.
		
		**/
		String processForecast(Cube cashFlowCube,String scenarioMember,String versionMember,String entityMember,String fixParallelDim,String startPeriod,String endPeriod)
		{
				boolean chkCategoryFixParallel=false,chkEntityIsFixParallel=false;
				String startEntityFix,endEntityFix,catStartFix,catEndFix,startFixParallel="",endFixParallel="",variableDeclaration="";
				String prjDimName="Category"
				String bankDimName="Bank";	
				String flexDim1Name = "flexDimension1";
				String flexDim2Name = "flexDimension2";
				String flexDim3Name = "flexDimension3";
				String forecastMethodDimName = "Forecast Method";
				String yearDimName="Years"
				String entityDimName = "Entity";
				String currencyDimName="Currency";
				String partyDimName="Party";
				String buDimName="Business Unit";
				List&lt;String> fixMembers=[];
				String variableString=getPreferedRangeVarialbeDeclaration();
				String varialStringForFixParallel=getPreferedRangeFixParllelVarialbeDeclaration();	
				if (fixParallelDim == entityDimName) chkEntityIsFixParallel=true;
				if (fixParallelDim == prjDimName) chkCategoryFixParallel=true;				
				if (chkEntityIsFixParallel == false)  
				{
					startEntityFix = """ Fix (@Relative("$entityMember",0)) """;
					endEntityFix ="ENDFIX"					
				}
				else
				{
					startEntityFix = """ 
										FIXPARALLEL (4,@Relative("$entityMember",0))
										$varialStringForFixParallel 
										"""
					endEntityFix ="ENDFIXPARALLEL"
				}
				if (chkCategoryFixParallel == false)  
				{
					catStartFix = """ 	FIX( @Relative("OEP_Total $prjDimName",0)) """;
					catEndFix ="ENDFIX"					
				}
				else
				{
					catStartFix = """  FIXPARALLEL (4,@Relative("OEP_Total $prjDimName",0)) 
										$varialStringForFixParallel
										"""
					catEndFix ="ENDFIXPARALLEL"
				}
				if (operation.application.hasDimension(fixParallelDim , cashFlowCube)  &amp;&amp; (chkCategoryFixParallel==false) &amp;&amp; (chkEntityIsFixParallel == false))
				{
					startFixParallel = """ FIXPARALLEL (4,@Relative("$fixParallelDim" ,0)) 
											 $varialStringForFixParallel
										"""
					endFixParallel = "ENDFIXPARALLEL"
				}
				
				if(operation.application.hasDimension(flexDim1Name, cashFlowCube) &amp;&amp; (fixParallelDim!=flexDim1Name)) 
				{  
				  fixMembers.add('@Relative("Total '+ flexDim1Name +'",0)') 
				}
				if(operation.application.hasDimension(flexDim2Name, cashFlowCube)&amp;&amp; (fixParallelDim!=flexDim2Name)) 
				{  
				  fixMembers.add('@Relative("Total '+ flexDim2Name +'",0)') 
				}
				if(operation.application.hasDimension(flexDim3Name, cashFlowCube) &amp;&amp; (fixParallelDim!=flexDim3Name) ) 
				{  
				  fixMembers.add('@Relative("Total '+ flexDim3Name +'",0)') 
				}
				if(operation.application.hasDimension(partyDimName, cashFlowCube) &amp;&amp; (fixParallelDim!=partyDimName)) 
				{  
				  fixMembers.add('@Relative("OEP_Total '+ partyDimName +'",0)') 				 
				}
				if(operation.application.hasDimension(buDimName, cashFlowCube) &amp;&amp; (fixParallelDim!=buDimName)) 
				{  
				  fixMembers.add('@Relative("OEP_Total '+ buDimName +'",0)') 
				}			
				if(operation.application.getCurrencyMode().equals(CurrencyMode.SIMPLIFIED_MULTI_CURRENCY))
				{  
				  fixMembers.add('@Relative("Input Currencies",0)');  
				}
				if (!operation.application.hasDimension(fixParallelDim, cashFlowCube) )
					  {	
						variableDeclaration="""									
									$variableString
						"""
					}	
				 String calcString ;	
