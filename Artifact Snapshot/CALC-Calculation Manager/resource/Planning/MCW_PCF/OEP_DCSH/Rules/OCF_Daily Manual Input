												  IF ((("OCF_Period Number" + $payTermPeriod) &lt;= $totalPeriods) AND (("OCF_Period Number" + $payTermPeriod) >= "OCF_Period Number"->$nextPeriod)  )
													IF (@CalcMgrIsLeapYear("OCF_Tp_date"))
														@MEMBERAT(@LIST(@CURRMBR("Period"):"$lastPeriod"),$payTermPeriod+1)->"$payTerm"->$yearOne = @MEMBERAT(@LIST(@CURRMBR("Period"):"$lastPeriod"),$payTermPeriod+1)->"$payTerm"->$yearOne+"$srcForecastMethod" * $payTermPercentage;	  
													ELSE
														IF (( @MEMBERAT(@LIST(@CURRMBR("Period"):"$lastPeriod"),$payTermPeriod+1)->"OCF_Tp_date">(@INT("OCF_Tp_date"/10000 )*10000 )+200+28 ) AND ( "OCF_Tp_date"&lt;=(@INT("OCF_Tp_date"/10000 )*10000 )+200+28 ) AND ( "OCF_Tp_date" == "OCF_Tp_EndDate") )
															@MEMBERAT(@LIST(@CURRMBR("Period"):"$lastPeriod"),$payTermPeriod+2)->"$payTerm"->$yearOne = @MEMBERAT(@LIST(@CURRMBR("Period"):"$lastPeriod"),$payTermPeriod+2)->"$payTerm"->$yearOne+"$srcForecastMethod" * $payTermPercentage;	
														ELSE
															@MEMBERAT(@LIST(@CURRMBR("Period"):"$lastPeriod"),$payTermPeriod+1)->"$payTerm"->$yearOne = @MEMBERAT(@LIST(@CURRMBR("Period"):"$lastPeriod"),$payTermPeriod+1)->"$payTerm"->$yearOne+"$srcForecastMethod" * $payTermPercentage;	
														ENDIF;
