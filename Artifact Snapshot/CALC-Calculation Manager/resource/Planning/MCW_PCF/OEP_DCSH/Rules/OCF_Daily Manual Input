													PrefRang3="No Currency"->"No Year"->"BegBalance"->$noFixMembersJoin->"OCF_Preferred Range 3" ;													
														IF( ("OCF_Period Number"+ "OCF_Period Number"->$endPeriod) &lt;= ("OCF_Period Number"->&amp;OEP_CurrYr->&amp;OEP_FcstStartPeriod +PrefRang1-1)) 
