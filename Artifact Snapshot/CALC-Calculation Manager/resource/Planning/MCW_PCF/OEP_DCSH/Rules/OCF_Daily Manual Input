			</script></rule></rules><components/><deployobjects><deployobject product="2" application="mcw_pcf" plantype="oep_dcsh" obj_id="1" obj_type="19" name="OCF_FORECAST UTILS_GT"/><deployobject product="2" application="mcw_pcf" plantype="oep_dcsh" obj_id="2" obj_type="19" name="OCF_PAY TERMS CALC UTILS_GT"/><deployobject product="2" application="mcw_pcf" plantype="oep_dcsh" obj_id="3" obj_type="19" name="OCF_MANUAL INPUT_GT"/><deployobject product="2" application="mcw_pcf" plantype="oep_dcsh" obj_id="1" obj_type="1" name="OCF_DAILY MANUAL INPUT"/></deployobjects><templates><template custom="yes" id="1" name="OCF_Forecast Utils_GT" product="Planning"><property name="application">MCW_PCF</property><property name="plantype">OEP_DCSH</property><property name="seeded">true</property><property name="standAlone">false</property><script type="groovy">		/***
		 * Returns number of Periods between first and last periods.
		 * 	@param  PeriodDimension, predicate is member function that give list of members, Cash cube names, First and last periods.					 
		 * 	@return  - returns count of number periods between first and last periods.		
		 **/
	  	int getPeriodCount(PeriodDimension periodDim,String Predicate, Cube cashCube,String firstPeriod,String lastPeriod)
			{
					int positionOfCurrPeriod = 0 ;
					int postionOfLastPeriod=0;
					  List&lt;Member> PeriodMbrs=periodDim.getEvaluatedMembers(Predicate,cashCube)
				  PeriodMbrs.eachWithIndex {it, i ->
							String strPeriod=it.toString();
							 if (strPeriod.equals(firstPeriod) )
								{
									positionOfCurrPeriod=i;
								}
							  if (strPeriod.equals(lastPeriod) )
								{
									postionOfLastPeriod=i;
								}  
				  }
				  return (postionOfLastPeriod-positionOfCurrPeriod+1);
			}
			
