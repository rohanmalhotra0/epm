<HBRRepo><variables/><rulesets/><rules/><components/><deployobjects><deployobject product="2" application="mcw_pcf" plantype="oep_dcsh" obj_id="1" obj_type="19" name="OCF_VALIDATIONS_GT"/></deployobjects><templates><template custom="yes" id="1" name="OCF_Validations_GT" product="Planning"><property name="application">MCW_PCF</property><property name="plantype">OEP_DCSH</property><property name="seeded">true</property><property name="standAlone">false</property><script type="groovy">			 /***
			 * Forecast by Bank is calculated based on defined drivers.
			 * @param cube,validationCateogry will be passed from rules
			 * returns Validation results or Veto Exception.	
			 * 1. DSO  and DPO number should be between 0 and 366			 
			**/
			boolean	cashForecastValidations(String cube,String validationCateogry)
			{
			  boolean  valResult=false;
				if (validationCateogry=="DSO")
				{
				  operation.grid.dataCellIterator("OCF_Average DSO").each {
						  if ((it.data &lt; 0) || (it.data > 366)) {
							valResult=true;
						}
					}
				}	
				else if (validationCateogry=="DPO")
				{
				 operation.grid.dataCellIterator("OCF_Average DPO").each {
						  if ((it.data &lt; 0) || (it.data > 366)) {
							valResult=true;
						}
					}
				}

			return valResult;
			}
			
			
