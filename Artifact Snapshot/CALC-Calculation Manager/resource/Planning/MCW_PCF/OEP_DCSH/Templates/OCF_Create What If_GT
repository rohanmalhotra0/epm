<HBRRepo><variables/><rulesets/><rules/><components/><deployobjects><deployobject product="2" application="mcw_pcf" plantype="oep_dcsh" obj_id="1" obj_type="19" name="OCF_CREATE WHAT IF_GT"/></deployobjects><templates><template custom="yes" id="1" name="OCF_Create What If_GT" product="Planning"><property name="application">MCW_PCF</property><property name="plantype">OEP_DCSH</property><property name="seeded">true</property><property name="standAlone">false</property><script type="groovy">	   /***
		 * Create What if on Rolling forecast Form.
		 * @param cube,mbrScenario,mbrVersion, mbrEntity,mbrYear,mbrPeriod,mbrCurrency will be passed from form context.
		 *  1) Copies data from Working into What if version from the selected period to last period of the Rolling forecast range.
		 *	2) Measure OCF_Display Scenario will be assigned value to show working and what if column.
		 *  3) OCF_Display Scenario is a display only member and its purpose to show the working and what if version as version dimension is hidden in the form.
		 *	 Unhiding it would show column for the periods that would not require to show.
		 *  4) This rule covers scenario where the rolling forecast window falls into 2 years. OCF_Number of Years variable will have 2 in case of rolling window crosses over 2 years.		 
		 * @return  - returns create What if version code.
		 **/
		String createWhatIf(String cube,String mbrScenario,String mbrVersion,String mbrEntity,String mbrYear,String mbrPeriod,String mbrCurrency)
		{
				String flexDim1Name = "flexDimension1";
				String flexDim2Name = "flexDimension2";
				String flexDim3Name = "flexDimension3";
				String partyDimName="Party";
				String buDimName="Business Unit";
				String prjDimName="Category";				
				String bankDimName="Bank";
				List&lt;String> noFixMembersList=[];
				List&lt;String> fixMembersList=[];
				String[] fRange,fmbrList;
				String numOfPeriods,forecastRange,Years,currentYearStartPeriod,currentYearEndPeriod,nextYearForecastRange,nexttYearStartPeriod,nextYearEndPeriod,noFixMembers,fixMembers;		
				def calcString;				
				Application application = operation.application;
				Cube cashFlowCube = application.getCube("$cube");
				numOfPeriods = getNumberOfYears(cashFlowCube);
				Years=getCurrentYear(cashFlowCube);				
				SubstitutionVariable subVariablePeriodRange=cashFlowCube.getSubstitutionVariable("OEP_CurrYrPeriodRange");
				forecastRange=subVariablePeriodRange.getValue()
				fRange = forecastRange.split(":");
				currentYearStartPeriod=fRange[0];
				currentYearEndPeriod=fRange[1];
				if (numOfPeriods=="2")
				{
				SubstitutionVariable subVariableNextPeriodRange=cashFlowCube.getSubstitutionVariable("OEP_NextYrPeriodRange");
				nextYearForecastRange=subVariableNextPeriodRange.getValue()
				fmbrList = nextYearForecastRange.split(":");
				nexttYearStartPeriod=fmbrList[0];
				nextYearEndPeriod=fmbrList[1];
				}
				if(application.hasDimension(flexDim1Name, cashFlowCube)) 
				{
				  noFixMembersList.add('"No '+ flexDim1Name +'"') 
				  fixMembersList.add('@Relative("Total '+ flexDim1Name +'",0)') 
				}
				if(operation.application.hasDimension(flexDim2Name, cashFlowCube))
				{
				  noFixMembersList.add('"No '+ flexDim2Name +'"') 
				  fixMembersList.add('@Relative("Total '+ flexDim2Name +'",0)')     
				}
				if(operation.application.hasDimension(flexDim3Name, cashFlowCube))
				{
				  noFixMembersList.add('"No '+ flexDim3Name +'"') 
				  fixMembersList.add('@Relative("Total '+ flexDim3Name +'",0)') 
				}
				if(application.hasDimension(prjDimName, cashFlowCube)) 
				{
					 noFixMembersList.add('"OEP_Any '+ prjDimName +'"') 					 
				}
				if(application.hasDimension(partyDimName, cashFlowCube)) 
				{
					 noFixMembersList.add('"OEP_Any '+ partyDimName +'"') 
					 fixMembersList.add('@Relative("OEP_Total '+ partyDimName +'",0)') 
				}
				if(application.hasDimension(buDimName, cashFlowCube))  
				{
					 noFixMembersList.add('"OEP_Any '+ buDimName +'"')
				     fixMembersList.add('@Relative("OEP_Total '+ buDimName +'",0)') 
				}
				if(application.hasDimension(bankDimName, cashFlowCube))  
				{
					 noFixMembersList.add('"OEP_Any '+ bankDimName +'"')
				     fixMembersList.add('@Relative("OEP_Any '+ bankDimName +'",0)') 
				}
				noFixMembers=noFixMembersList.join(',');
				fixMembers=fixMembersList.join(',');

				if (numOfPeriods=="2")
					{
				if ("$mbrYear" == "$Years")
					{
						calcString =
						"""
						 SET UPDATECALC OFF;
						 SET AGGMISSG ON;	
						 FIX("$mbrScenario","$mbrEntity","$mbrCurrency")
						   FIX(&amp;OEP_CurrYr,$mbrPeriod:$currentYearEndPeriod)
								FIX($noFixMembers,"OCF_Display Scenario","OCF_Forecasted")
									"OEP_Working"=1;
									"OEP_What If"=2;
								ENDFIX
								FIX($fixMembers,"OCF_Forecasted","OCF_Adjustments")
									FIX(@Relative("$prjDimName",0),@Relative("OCF_Total Cash",0),"OCF_Opening Balance")										 
											DATACOPY "$mbrVersion" to "OEP_What If";										  
									ENDFIX;
									FIX("$mbrVersion","OEP_What If",@Relative("OCF_Total Cash",0),"OCF_Opening Balance","OCF_Display Scenario")
										@IDESCENDANTS("OEP_Total $prjDimName");
									ENDFIX;	
								ENDFIX           								
						   ENDFIX;
						   FIX(&amp;OEP_NextYr,$nexttYearStartPeriod:$nextYearEndPeriod)
								FIX($noFixMembers,"OCF_Display Scenario","OCF_Forecasted")
									"OEP_Working"=1;
									"OEP_What If"=2;
								ENDFIX
								FIX($fixMembers,"OCF_Forecasted","OCF_Adjustments")
									FIX(@Relative("$prjDimName",0),@Relative("OCF_Total Cash",0),"OCF_Opening Balance")
										DATACOPY "$mbrVersion" to "OEP_What If";
									ENDFIX;
									FIX("$mbrVersion","OEP_What If",@Relative("OCF_Total Cash",0),"OCF_Opening Balance","OCF_Display Scenario")
										@IDESCENDANTS("OEP_Total $prjDimName");
									ENDFIX;
								ENDFIX           
								
								
						   ENDFIX;
						 ENDFIX;
						"""
					}
					else
					{
						calcString =
						"""
						 SET UPDATECALC OFF;
						 SET AGGMISSG ON;		
						 FIX("$mbrScenario","$mbrEntity","$mbrCurrency")
						   FIX(&amp;OEP_NextYr,$mbrPeriod:$nextYearEndPeriod)
								FIX($noFixMembers,"OCF_Display Scenario","OCF_Forecasted")
									"OEP_Working"=1;
									"OEP_What If"=2;
								ENDFIX
								FIX($fixMembers,"OCF_Forecasted","OCF_Adjustments")
									FIX(@Relative("$prjDimName",0),@Relative("OCF_Total Cash",0),"OCF_Opening Balance")
										DATACOPY "$mbrVersion" to "OEP_What If";
									ENDFIX;
									FIX("$mbrVersion","OEP_What If",@Relative("OCF_Total Cash",0),"OCF_Opening Balance","OCF_Display Scenario")
										@IDESCENDANTS("OEP_Total $prjDimName");
									ENDFIX;
								ENDFIX								
						   ENDFIX;
						 ENDFIX;
						"""
					}
					}				
					else
					{
						calcString =
						"""
						 SET UPDATECALC OFF;
						 SET AGGMISSG ON;	
						 FIX("$mbrScenario","$mbrEntity","$mbrCurrency")
						   FIX(&amp;OEP_CurrYr,$mbrPeriod:$currentYearEndPeriod)
								FIX($noFixMembers,"OCF_Display Scenario","OCF_Forecasted",$mbrPeriod:$currentYearEndPeriod)
									"OEP_Working"=1;
									"OEP_What If"=2;
								ENDFIX
								FIX($fixMembers,"OCF_Forecasted","OCF_Adjustments",$mbrPeriod:$currentYearEndPeriod)
									FIX("OCF_Opening Balance",@Relative("$prjDimName",0),@Relative("OCF_Total Cash",0),"OCF_Opening Balance")
										DATACOPY "$mbrVersion" to "OEP_What If";
									ENDFIX;
									FIX("$mbrVersion","OEP_What If",@Relative("OCF_Total Cash",0),"OCF_Opening Balance","OCF_Display Scenario")
										@IDESCENDANTS("OEP_Total $prjDimName");
									ENDFIX;
								ENDFIX;           
						   ENDFIX;
						 ENDFIX;
						"""
					}							
				return calcString;	
		}
</script><template_wizard/><template_prompts><restricted_prompt name="Application Type" type="Application Type" isPrompt="no"><property name="is_system">true</property><restricted_prompt_item><property name="prompt">Is Generic</property><property name="value">GENERAL</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is PFP</property><property name="value">PROJECT</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is PSB</property><property name="value">PSB</property></restricted_prompt_item></restricted_prompt><restricted_prompt name="Application" type="Application" isPrompt="no"><property name="is_system">true</property><value>Is Single Currency</value><restricted_prompt_item><property name="prompt">Is Multi Currency</property><property name="value">multi</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is Single Currency</property><property name="value">single</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is Simple Currency</property><property name="value">simple</property></restricted_prompt_item></restricted_prompt><template_slice_prompt name="UpperPOV" type="Member Range" isPrompt="false"><property name="is_system">true</property></template_slice_prompt><restricted_prompt name="Essbase Mode" type="Essbase Mode" isPrompt="no"><property name="is_system">true</property><restricted_prompt_item><property name="prompt">Is Hybrid</property><property name="value">Hybrid</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is NonHybrid</property><property name="value">NonHybrid</property></restricted_prompt_item></restricted_prompt></template_prompts></template></templates></HBRRepo>