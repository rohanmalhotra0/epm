<HBRRepo><variables/><rulesets/><rules/><components/><deployobjects><deployobject product="2" application="mcw_pcf" plantype="oep_dcsh" obj_id="1" obj_type="19" name="OCF_FORECAST BY BANK_GT"/></deployobjects><templates><template custom="yes" id="1" name="OCF_Forecast By Bank_GT" product="Planning"><property name="application">MCW_PCF</property><property name="plantype">OEP_DCSH</property><property name="seeded">true</property><property name="standAlone">false</property><script type="groovy">			 /***
			 * Forecast by Bank is calculated based on defined drivers.
			 * @param cube, scenario, version, entity will be passed from form context.
			 * @param  startperiod  and end periods, Daily, weekly and Monthly first and last period of corresponding period dimension.
			 * @param fixParallelDim  - name of the dimension on which fix parallel to be applied.
			 * @return  - returns calculation script that computes Forecast by Bank.
			 * 1. User picks allocation method and saves the form and runs the bank by allocation method explicitly
			 * 2. This rule allocates the number from Any bank to respective bank based on the allocation method.
			 * 3. Current Year YTD Balance = Multiplies Any bank number with given bank YTD balance / Total YTD balance of all banks.
			 * 4. Previous Year Balance= Allocates Any bank amount to respective bank of previous year average balance.
			 * 5. Opening Balance- Allocates based on the opening balance of current period for all future periods.
			 * 6. Last Year Same Period Balance=  Any bank amount is multiplied by last year same period bank balance / total bank balance of same period. 
			**/
			String	calculateForecastByBank(String cube,String scenarioMember,String versionMember,String entityMember,String startPeriod,String endPeriod)
			{	
				StringBuilder cscript = new StringBuilder(); 
				def calcString;
				String flexDim1Name = "flexDimension1";
				String flexDim2Name = "flexDimension2";
				String flexDim3Name = "flexDimension3";
				String currencyDimName="Currency";
				String partyDimName="Party";
				String bankDimName="Bank";
				String buDimName="Business Unit";
				String prjDimName="Category"
				String forecastMethodDimName = "Forecast Method";
				String yearDimName="Years"				
				String entityDimName = "Entity";		
				Application application = operation.application;
				Cube cashFlowCube = application.getCube(cube);
				List&lt;String> noFixMembers=[];
				List&lt;String> nofixMembersWOCategory=[];
				List&lt;String> fixTotalMembers=[];
				String numOfPeriods = getNumberOfYears(cashFlowCube);
				if(application.hasDimension(flexDim1Name, cashFlowCube)) 
				{
				  noFixMembers.add('"No '+ flexDim1Name +'"');  				  
				  fixTotalMembers.add('"Total '+ flexDim1Name +'"')
				  nofixMembersWOCategory.add('"No '+ flexDim1Name +'"');  
				}
				if(operation.application.hasDimension(flexDim2Name, cashFlowCube))
				{
				  noFixMembers.add('"No '+ flexDim2Name +'"') ;  				  
				  fixTotalMembers.add('"Total '+ flexDim2Name +'"')
				  nofixMembersWOCategory.add('"No '+ flexDim2Name +'"');  
				}
				if(operation.application.hasDimension(flexDim3Name, cashFlowCube))
				{
				   noFixMembers.add('"No '+ flexDim3Name +'"'); 				  
				   fixTotalMembers.add('"Total '+ flexDim3Name +'"')
				   nofixMembersWOCategory.add('"No '+ flexDim3Name +'"');
				}
				if(operation.application.hasDimension(partyDimName, cashFlowCube))
				{
				  noFixMembers.add('"OEP_Any '+ partyDimName +'"');				  
				  fixTotalMembers.add('"OEP_Total '+ partyDimName +'"')
				  nofixMembersWOCategory.add('"OEP_Any '+ partyDimName +'"');
				}
				if(operation.application.hasDimension(buDimName, cashFlowCube))
				{
				  noFixMembers.add('"OEP_Any '+ buDimName +'"'); 				  
				  fixTotalMembers.add('"OEP_Total '+ buDimName +'"')
					nofixMembersWOCategory.add('"OEP_Any '+ buDimName +'"'); 				  
				}
				if(operation.application.hasDimension(prjDimName, cashFlowCube))
				{
				   noFixMembers.add('"OEP_Any '+ prjDimName +'"'); 				 
				   fixTotalMembers.add('"OEP_Total '+ prjDimName +'"')	
				}
				
				String noFixMembersJoinStr=noFixMembers.join("->");
				String noFixMembersStr=nofixMembersWOCategory.join(",");				
				String fixMembersJoinStr=fixTotalMembers.join("->");
				  if (numOfPeriods=="2")
				  {
				   calcString="""
						  	FIX(@Relative("$entityMember",0),"$scenarioMember","$versionMember",@Relative("Input Currencies",0),"OCF_Forecasted",@Relative("OEP_All $bankDimName",0 ),$noFixMembersStr)
								FIX("OEP_Any $prjDimName")									 
									 FIX( &amp;OEP_CurrYrPeriodRange,&amp;OEP_CurrYr)
										CLEARDATA "OCF_Bank Balance";
									   "OCF_Bank Balance" ( 	
										 IF ("No Currency"->"OEP_Any $bankDimName"->$noFixMembersJoinStr->"BegBalance"->"OCF_Cash Drivers"->"OCF_Bank Alloc Method"==1.0)
										 "OCF_Bank Balance"= 
										 ("OCF_Closing Balance"->"OCF_Total Forecasted Cash"->"OEP_Total $bankDimName"->$fixMembersJoinStr * @AVGRANGE(SKIPNONE ,"OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_CurrYr->"OCF_Bank Balance", "$startPeriod":"$endPeriod") / @AVGRANGE(SKIPNONE ,"OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_CurrYr->"OEP_Total $bankDimName"->"OCF_Bank Balance", "$startPeriod":"$endPeriod"))  ;									
										 ELSEIF("No Currency"->"OEP_Any $bankDimName"->$noFixMembersJoinStr->"BegBalance"->"OCF_Cash Drivers"->"OCF_Bank Alloc Method"==2.0)
										 "OCF_Bank Balance"= ("OCF_Closing Balance"->"OCF_Total Forecasted Cash"->"OEP_Total $bankDimName"->$fixMembersJoinStr * @AVGRANGE(SKIPNONE ,"OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_PriorYr->"OCF_Bank Balance", "$startPeriod":"$endPeriod") / @AVGRANGE(SKIPNONE ,"OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_PriorYr->"OEP_Total $bankDimName"->"OCF_Bank Balance", "$startPeriod":"$endPeriod"))  ;								  
										 ELSEIF("No Currency"->"OEP_Any $bankDimName"->$noFixMembersJoinStr->"BegBalance"->"OCF_Cash Drivers"->"OCF_Bank Alloc Method"==3.0)
										"OCF_Bank Balance"= ( "OCF_Closing Balance"->"OCF_Total Forecasted Cash"->"OEP_Total $bankDimName"->$fixMembersJoinStr * "OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_ActPeriod->"OCF_Bank Balance" / "OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_ActPeriod->"OEP_Total $bankDimName"->"OCF_Bank Balance")  ;
										 ELSEIF("No Currency"->"OEP_Any $bankDimName"->$noFixMembersJoinStr->"BegBalance"->"OCF_Cash Drivers"->"OCF_Bank Alloc Method"==4.0)
										"OCF_Bank Balance"= ( "OCF_Closing Balance"->"OCF_Total Forecasted Cash"->"OEP_Total $bankDimName"->$fixMembersJoinStr * "OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_PriorYr->"OCF_Bank Balance" / "OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_PriorYr->"OEP_Total $bankDimName"->"OCF_Bank Balance")  ;
										 ENDIF;
										 );
									 ENDFIX;
									 FIX( &amp;OEP_NextYrPeriodRange,&amp;OEP_NextYr)
										CLEARDATA "OCF_Bank Balance";
									   "OCF_Bank Balance" ( 	
										 IF ("No Currency"->"OEP_Any $bankDimName"->$noFixMembersJoinStr->"BegBalance"->"OCF_Cash Drivers"->"OCF_Bank Alloc Method"==1.0)
										 "OCF_Bank Balance"= 
										 ("OCF_Closing Balance"->"OCF_Total Forecasted Cash"->"OEP_Total $bankDimName"->$fixMembersJoinStr * @AVGRANGE(SKIPNONE ,"OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_CurrYr->"OCF_Bank Balance", "$startPeriod":"$endPeriod") / @AVGRANGE(SKIPNONE ,"OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_CurrYr->"OEP_Total $bankDimName"->"OCF_Bank Balance", "$startPeriod":"$endPeriod"))  ;									
										 ELSEIF("No Currency"->"OEP_Any $bankDimName"->$noFixMembersJoinStr->"BegBalance"->"OCF_Cash Drivers"->"OCF_Bank Alloc Method"==2.0)
										 "OCF_Bank Balance"= ("OCF_Closing Balance"->"OCF_Total Forecasted Cash"->"OEP_Total $bankDimName"->$fixMembersJoinStr * @AVGRANGE(SKIPNONE ,"OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_PriorYr->"OCF_Bank Balance", "$startPeriod":"$endPeriod") / @AVGRANGE(SKIPNONE ,"OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_PriorYr->"OEP_Total $bankDimName"->"OCF_Bank Balance", "$startPeriod":"$endPeriod"))  ;								  
										 ELSEIF("No Currency"->"OEP_Any $bankDimName"->$noFixMembersJoinStr->"BegBalance"->"OCF_Cash Drivers"->"OCF_Bank Alloc Method"==3.0)
										"OCF_Bank Balance"= ( "OCF_Closing Balance"->"OCF_Total Forecasted Cash"->"OEP_Total $bankDimName"->$fixMembersJoinStr * "OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_ActPeriod->"OCF_Bank Balance" / "OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_ActPeriod->"OEP_Total $bankDimName"->"OCF_Bank Balance")  ;
										 ELSEIF("No Currency"->"OEP_Any $bankDimName"->$noFixMembersJoinStr->"BegBalance"->"OCF_Cash Drivers"->"OCF_Bank Alloc Method"==4.0)
										"OCF_Bank Balance"= ( "OCF_Closing Balance"->"OCF_Total Forecasted Cash"->"OEP_Total $bankDimName"->$fixMembersJoinStr * "OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_PriorYr->"OCF_Bank Balance" / "OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_PriorYr->"OEP_Total $bankDimName"->"OCF_Bank Balance")  ;
										 ENDIF;
										 );
									ENDFIX;
								ENDFIX;
								FIX("OCF_Bank Balance")
										FIX( &amp;OEP_CurrYrPeriodRange,&amp;OEP_CurrYr)
											@IANCESTOR("OEP_Any $prjDimName");
										ENDFIX
										FIX( &amp;OEP_NextYrPeriodRange,&amp;OEP_NextYr)
											@IANCESTOR("OEP_Any $prjDimName");
										ENDFIX;
								ENDFIX;
							ENDFIX;                 
					 """ 
					 cscript.append(calcString)  
					
					
				  }
				  else
				  {
				  
				 calcString="""
						  	FIX(@Relative("$entityMember",0),"$scenarioMember","$versionMember",@Relative("Input Currencies",0),&amp;OEP_CurrYr,"OCF_Forecasted",@Relative("OEP_All $bankDimName",0 ),$noFixMembersStr,&amp;OEP_CurrYrPeriodRange)							
									FIX("OEP_Any $prjDimName")									
										CLEARDATA "OCF_Bank Balance";										
									   "OCF_Bank Balance" ( 	
										 IF ("No Currency"->"OEP_Any $bankDimName"->$noFixMembersJoinStr->"BegBalance"->"OCF_Cash Drivers"->"OCF_Bank Alloc Method"==1.0)
										 "OCF_Bank Balance"= 
										 ("OCF_Closing Balance"->"OCF_Total Forecasted Cash"->"OEP_Total $bankDimName"->$fixMembersJoinStr * @AVGRANGE(SKIPNONE ,"OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_CurrYr->"OCF_Bank Balance", "$startPeriod":"$endPeriod") / @AVGRANGE(SKIPNONE ,"OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_CurrYr->"OEP_Total $bankDimName"->"OCF_Bank Balance", "$startPeriod":"$endPeriod"))  ;									
										 ELSEIF("No Currency"->"OEP_Any $bankDimName"->$noFixMembersJoinStr->"BegBalance"->"OCF_Cash Drivers"->"OCF_Bank Alloc Method"==2.0)
										 "OCF_Bank Balance"= ("OCF_Closing Balance"->"OCF_Total Forecasted Cash"->"OEP_Total $bankDimName"->$fixMembersJoinStr * @AVGRANGE(SKIPNONE ,"OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_PriorYr->"OCF_Bank Balance", "$startPeriod":"$endPeriod") / @AVGRANGE(SKIPNONE ,"OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_PriorYr->"OEP_Total $bankDimName"->"OCF_Bank Balance", "$startPeriod":"$endPeriod"))  ;								  
										 ELSEIF("No Currency"->"OEP_Any $bankDimName"->$noFixMembersJoinStr->"BegBalance"->"OCF_Cash Drivers"->"OCF_Bank Alloc Method"==3.0)
										"OCF_Bank Balance"= ( "OCF_Closing Balance"->"OCF_Total Forecasted Cash"->"OEP_Total $bankDimName"->$fixMembersJoinStr * "OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_ActPeriod->"OCF_Bank Balance" / "OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_ActPeriod->"OEP_Total $bankDimName"->"OCF_Bank Balance")  ;									
										 ELSEIF("No Currency"->"OEP_Any $bankDimName"->$noFixMembersJoinStr->"BegBalance"->"OCF_Cash Drivers"->"OCF_Bank Alloc Method"==4.0)
										"OCF_Bank Balance"= ( "OCF_Closing Balance"->"OCF_Total Forecasted Cash"->"OEP_Total $bankDimName"->$fixMembersJoinStr * "OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_PriorYr->"OCF_Bank Balance" / "OEP_Actual"->"OCF_Smart Drivers"->&amp;OEP_PriorYr->"OEP_Total $bankDimName"->"OCF_Bank Balance")  ;
										 ENDIF;
										 );
									ENDFIX;									
									FIX("OCF_Bank Balance")
										@IANCESTOR("OEP_Any $prjDimName");
									ENDFIX;
							ENDFIX;                 
					 """ 
						cscript.append(calcString)  
						
					
				  }	

					
					return cscript;  		
				
			}
</script><template_wizard/><template_prompts><restricted_prompt name="Application Type" type="Application Type" isPrompt="no"><property name="is_system">true</property><restricted_prompt_item><property name="prompt">Is Generic</property><property name="value">GENERAL</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is PFP</property><property name="value">PROJECT</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is PSB</property><property name="value">PSB</property></restricted_prompt_item></restricted_prompt><restricted_prompt name="Application" type="Application" isPrompt="no"><property name="is_system">true</property><value>Is Single Currency</value><restricted_prompt_item><property name="prompt">Is Multi Currency</property><property name="value">multi</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is Single Currency</property><property name="value">single</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is Simple Currency</property><property name="value">simple</property></restricted_prompt_item></restricted_prompt><template_slice_prompt name="UpperPOV" type="Member Range" isPrompt="false"><property name="is_system">true</property></template_slice_prompt><restricted_prompt name="Essbase Mode" type="Essbase Mode" isPrompt="no"><property name="is_system">true</property><restricted_prompt_item><property name="prompt">Is Hybrid</property><property name="value">Hybrid</property></restricted_prompt_item><restricted_prompt_item><property name="prompt">Is NonHybrid</property><property name="value">NonHybrid</property></restricted_prompt_item></restricted_prompt></template_prompts></template></templates></HBRRepo>