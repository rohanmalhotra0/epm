# =============================================================================
# EPM Wizard — example environment file
# =============================================================================
# Copy to `.env` for local runs. NONE of these are required to start the app:
# EPM Wizard boots in Demo Mode with a deterministic local AI provider so it is
# fully usable with zero configuration. Provider keys are normally entered in
# the UI (Settings -> AI Providers) and stored in the local encrypted secret
# store, NOT here. This file only exists for convenience / CI.
#
# Secrets in this file are NEVER sent to a language model, logged, or committed.
# `.env` is gitignored.
# -----------------------------------------------------------------------------

# ---- Ports (host side) ------------------------------------------------------
EPMW_FRONTEND_PORT=3000
EPMW_BACKEND_PORT=8000

# ---- Backend runtime --------------------------------------------------------
# Directory (inside the backend container / process) for the SQLite DB, secret
# store, artifacts and context packages. In Docker this is a named volume.
EPMW_DATA_DIR=/data
EPMW_LOG_LEVEL=INFO
EPMW_LOG_JSON=true

# ---- Optional multi-user owner-scoping (OFF by default) ---------------------
# When false (the default) the app is single-user: every project belongs to the
# implicit "local" owner and behavior is unchanged. Set true only behind a
# reverse proxy that authenticates users and injects an identity header; each
# project is then scoped to its owner (legacy/unowned projects stay visible to
# all). The header carrying the authenticated email is configurable.
# EPMW_MULTI_USER=false
# EPMW_AUTH_EMAIL_HEADER=X-Forwarded-Email

# External database URL for hosted deployments. Leave unset for the default
# local SQLite database (sqlite:///<EPMW_DATA_DIR>/epmwizard.db) — nothing else
# is required for local runs. When set, it wins over the SQLite path. For IBM
# Cloud Databases for PostgreSQL use the psycopg (v3) driver; ICD *requires*
# TLS, and its CA certificate must be available on disk (in Code Engine, mount
# it from a secret and point sslrootcert at the mount path):
# EPMW_DATABASE_URL=postgresql+psycopg://user:pass@host:port/db?sslmode=verify-full&sslrootcert=/path/ca.pem

# Master key used to derive the local encrypted secret store (Fernet). If unset,
# a key is generated on first run and stored (0600) under EPMW_DATA_DIR/keys.
# Set this explicitly if you want a stable key across volume resets.
# EPMW_SECRET_MASTER_KEY=

# ---- Optional AI provider defaults (UI configuration is preferred) ----------
# The Anthropic provider will fall back to these if no UI-configured key exists.
# ANTHROPIC_API_KEY=
# CLAUDE_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# Embedding model for RAG grounding when an OpenAI-compatible provider is active.
# OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# ---- IBM watsonx.ai (all-IBM deployment; see docs/IBM_CLOUD.md) --------------
# The API key is a standard IBM Cloud API key (exchanged for an IAM token).
# WATSONX_API_KEY=
# Regional watsonx.ai endpoint (us-south, eu-de, eu-gb, jp-tok, au-syd, ...)
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
# The watsonx.ai project that scopes inference (Manage -> General -> Project ID),
# or set WATSONX_SPACE_ID instead to use a deployment space.
# WATSONX_PROJECT_ID=
# WATSONX_SPACE_ID=
# Chat/generation model used when the provider profile has no default model.
# meta-llama/llama-3-3-70b-instruct is the recommended token-billed model for
# EPM Wizard (131k context, strong structured output; see docs/IBM_CLOUD.md).
# WATSONX_CHAT_MODEL_ID=meta-llama/llama-3-3-70b-instruct
# Embedding model for RAG grounding of /forms and /rules (retrieval over the
# active context); defaults to IBM's slate retriever when unset.
# WATSONX_EMBEDDINGS_MODEL_ID=ibm/slate-125m-english-rtrvr

# ---- Optional EPM Automate runner -------------------------------------------
# Path to a locally-installed EPM Automate binary (Oracle software is NOT
# redistributed by this project — mount or install it yourself). Leave unset to
# stay in Demo Mode.
# EPMW_EPMAUTOMATE_PATH=/opt/epmautomate/bin/epmautomate.sh
# JAVA_HOME=/usr/lib/jvm/java-11
#
# Member/dimension members are not exposed by the Planning REST API, so they are
# imported by running a saved "Export Metadata" job via EPM Automate and parsing
# the download. Create an Export Metadata job in the app, then set its name here.
# Members stay empty (dimensions/cubes still work) until BOTH this and
# EPMW_EPMAUTOMATE_PATH are set.
# EPMW_ORACLE_METADATA_JOB=EPM Wizard Metadata Export
#
# Alternative that needs NO saved job: point at an existing LCM application
# snapshot (e.g. the daily "Artifact Snapshot"). EPM Automate downloads it and
# members are parsed from the dimension files inside. Used only when
# EPMW_ORACLE_METADATA_JOB is unset. Requires EPMW_EPMAUTOMATE_PATH.
# EPMW_ORACLE_METADATA_SNAPSHOT=Artifact Snapshot
