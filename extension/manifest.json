{
  "manifest_version": 3,
  "name": "EPM Wizard — Narrated Browser Agent",
  "version": "0.1.0",
  "description": "Watches and narrates as it drives Oracle EPM Cloud's web UI. Accessibility-tree grounding + screenshot fallback, side-panel narration. (Scaffold.)",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs",
    "storage",
    "debugger"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://localhost/*"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Open EPM Wizard agent panel"
  }
}
